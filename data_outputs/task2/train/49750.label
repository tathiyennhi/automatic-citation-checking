  "bib_entries": {
    "11202846": {
      "title": "Dual-polarity plasmonic metalens for visible light",
      "abstract": "The wide range of properties encountered in metamaterials make them promising for numerous optical applications. Chen et al. build a plasmonic flat metamaterial lens with an abrupt phase change that functions as a convex lens for one handedness of light and a concave lens for the other."
    }
