  "bib_entries": {
    "55773188": {
      "title": "The bardeen model as a nonlinear magnetic monopole",
      "abstract": "Abstract The Bardeen model \u2014 the first regular black hole model in General Relativity \u2014 is reinterpreted as the gravitational field of a nonlinear magnetic monopole, i.e., as a magnetic solution to Einstein equations coupled to a nonlinear electrodynamics."
    }
  }
}