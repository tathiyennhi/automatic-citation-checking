  "bib_entries": {
    "122021803": {
      "title": "Almost sure consistent nonparametric regression from recursive partitioning schemes",
      "abstract": "Presented here are results on almost sure convergence of estimators of regression functions subject to certain moment restrictions. Two somewhat different notions of almost sure convergence are studied: unconditional and conditional given a training sample. The estimators are local means derived from certain recursive partitioning schemes."
    },
