{
  "texts": [
    "For any F = ⟨S, ⊑, {R i } i∈I, P ⟩, the following are equivalent:1.",
    "F is a rich frame; 2.",
    "F is a principal possibility frame that is lattice-complete and satisfies R-tight;3.",
    "F is a principal possibility frame that is lattice-complete and satisfies R-princ;4.",
    "F is a full possibility frame in which ⟨S ⊥, ⊑ ⊥ ⟩ is a complete Boolean lattice, satisfying R-tight;5."
  ]
}