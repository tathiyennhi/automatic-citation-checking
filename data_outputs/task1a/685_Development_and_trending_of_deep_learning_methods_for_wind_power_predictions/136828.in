{
  "texts": [
    "L i and U i are the estimated lower and upper bound of the i th sample in the dataset.",
    "F i (y) is the estimated cumulative distribution function of the i th sample in the dataset.",
    "y * i is the normalized actual wind power output of the i th sample in the dataset.",
    "r is the number of estimated quantile in a sample.",
    "j is the j th nominal quantile in a sample."
  ]
}