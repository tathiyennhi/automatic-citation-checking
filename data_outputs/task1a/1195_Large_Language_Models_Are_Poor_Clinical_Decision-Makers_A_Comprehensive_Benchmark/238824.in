{
  "texts": [
    "effect: This type is used to annotate DDIs describing an effect (e.g.",
    "In uninfected volunteers, 46% developed rash while receiving SUSTIVA and clarithromycin) or a PD mechanism (e.g.",
    "Chlorthali done may potentiate the action of other antihypertensive drugs).",
    "advice: This type is used when a recommendation or advice Regarding a drug interaction is given (e.g.",
    "UROXATRAL should not be used in combination with other alpha-blockers)."
  ]
}