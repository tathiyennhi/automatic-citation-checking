    "Listing 2 Estimating the Overall Effect Based on a Multivariate Meta-Analytic Approach with an Approximated Variance-Covariance Matrix of ρ =.60.",
    "# Calculating the approximated variance-covariance matrix by # assuming a correlation between effect sizes within studies of rho=.",
    "cluster=studyID, obs=effectsizeID, data=dataset, rho=0.6) # Estimating the overall effect based on the multivariate # approach with an approximated variance-covariance matrix.",
    "overallmultivariate <-rma.mv(y, vcmatrix, random=list(~1 | effectsizeID, ~1 | studyID), tdist=TRUE, data=dataset) # Request a print of the results stored in the object # \"overallmultivariate\" in three digits.",
    "summary(overallmultivariate, digits=3) different."
  ]
}