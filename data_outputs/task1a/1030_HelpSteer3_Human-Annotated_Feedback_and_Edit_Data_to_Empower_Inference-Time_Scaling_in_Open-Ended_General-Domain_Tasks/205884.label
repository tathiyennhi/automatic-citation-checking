{
  "style": "APA",
  "texts": [
    "Arena Hard contains 500 first-turn instructions obtained from challenging user queries on Chatbot Arena (Chiang et al., 2024).",
    "Prompts are classified using an LLM (Llama-3-70B-Instruct) to determine if they are complex, specific, real-world-application-related or require domain knowledge, problem-solving, creativity, technical accuracy.",
    "Prompts that meet at least 6 out of 7 criteria are labelled as challenging.",
    "Therefore, a huge proportion of prompts (>50%) are related to solving coding problems.",
    "There is also a small fraction of samples involving multlingual capabilities."
  ],
  "correct_citations": [
    "Arena Hard contains 500 first-turn instructions obtained from challenging user queries on Chatbot Arena (Chiang et al., 2024)."
  ]
}