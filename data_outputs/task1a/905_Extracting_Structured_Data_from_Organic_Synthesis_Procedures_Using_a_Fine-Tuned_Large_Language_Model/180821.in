    "Generated Ground Truth \"identifiers\": [{ \"type\": \"NAME\", \"value\": \"KCl\"}], \"amount\": { \"mass\": {\"value\": 1.2, \"units\": \"GRAM\"}}}, \"identifiers\": [{ \"type\": \"NAME\", \"value\": \"NaCl\"}], \"amount\": { \"mass\": {\"value\": 0.32, \"units\": \"GRAM\"}}, \"reaction_role\": \"REACTANT\"}}, \"identifiers\": [{ \"type\": \"NAME\", \"value\": \"NH4Cl\"}], \"amount\": { \"mass\": {\"value\": 2.1, \"units\": \"GRAM\"}}},............"
