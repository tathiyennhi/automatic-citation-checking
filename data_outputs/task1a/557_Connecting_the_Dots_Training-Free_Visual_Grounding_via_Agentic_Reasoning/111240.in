{
  "texts": [
    "This supports the choice of 10 as a conservative upper bound, balancing completeness with reasoning efficiency.",
    "PromptsVG_TEXT_GROUNDER_w_QUERY = '''\\ You are a subject extractor, and you need to extract the subject from the object positioning description I give you.",
    "For example, \"the painting hanging on the laptop\", you need to return to me the real target subject of the sentence \"painting\".Available noun examples: {noun_examples} You need to list all possible nouns.",
    "For example, if I provide \"left kid in blue shirt,\" your output should be \"kid, child, person, shirt\", with as many similar nouns as possible.",
    "Your output should only be the extracted nouns."
  ]
