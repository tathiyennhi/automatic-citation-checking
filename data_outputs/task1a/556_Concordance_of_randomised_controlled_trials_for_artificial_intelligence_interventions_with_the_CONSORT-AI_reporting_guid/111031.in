{
  "texts": [
    "Clinical trial registries, including the International Clinical Trials Registry Platform and ClinicalTrials.gov, were searched for completed studies on the same date.",
    "Articles published from 9th September 2020 onwards were retrieved for screening, following the date of CONSORT-AI publication.",
    "Articles were restricted to English language.",
    "Reference lists of included articles and identified secondary research sources were screened for relevant articles before exclusion.",
    "The database searches were not repeated."
  ]
}