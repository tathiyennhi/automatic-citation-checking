{
  "texts": [
    "Library indicates the CDM library being described.",
    "Anatomical Area shows the region of the fly central nervous system covered by the library.",
    "Samples shows the number of biological samples which form the original data set.",
    "Neuron Images indicates the total number of individual images containing neurons derived from these samples.",
    "Searchable Files indicates the number of CDM images in the library that can be searched."
  ]
}