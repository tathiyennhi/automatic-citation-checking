    "Question Gold SQL Type 33 Show the Airports with elevation more than 3000 SELECT name FROM mondial_airport WHERE elevation > 3000.0 simple 59 What are the area, elevation and type of lakes in Italy?",
    "SELECT l.area, l.elevation, l.type FROM mondial_geo_lake gl, mondial_lake l, mondial_country c WHERE (gl.LAKE = l.NAME) AND (gl.COUNTRY = c.CODE) AND c.name = \"Italy\" complex 99 What type of government is Iran?",
