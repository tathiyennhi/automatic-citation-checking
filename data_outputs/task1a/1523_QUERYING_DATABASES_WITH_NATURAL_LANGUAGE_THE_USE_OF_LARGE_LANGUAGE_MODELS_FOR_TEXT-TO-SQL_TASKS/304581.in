{
  "texts": [
    "The SQL query for the sub -question \" What is the title, credit value, and department name for courses with more than one prerequisite?\" is SELECT T1.",
    "title, T1. credits, T1.",
    "dept_name FROM course T1 JOIN prereq T2 ON T1. course_id = T2.",
    "course_id GROUP BY T2.",
    "course_id HAVING count (*) > 1"
  ]
}