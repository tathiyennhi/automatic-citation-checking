{
  "style": "APA",
  "texts": [
    "• Financial Phrase Bank (FPB) (Malo et al., 2013), is a dataset for sentiment analysis in financial news.",
    "It contains 4,840 sentences sourced from English-language financial news articles, categorized by sentiment as positive, negative, or neutral.",
    "Each sentence reflects the sentiment an investor might perceive from the news with respect to its influence on stock prices.",
    "The dataset is annotated by a group of 16 annotators with a background in finance, using a majority vote approach.",
    "It is available in four different configurations based on annotator agreement levels (50%, 66%, 75%, and 100%)."
  ],
  "correct_citations": [
    "• Financial Phrase Bank (FPB) (Malo et al., 2013), is a dataset for sentiment analysis in financial news."
  ]
}