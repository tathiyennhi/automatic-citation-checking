{
  "texts": [
    "# Compute the extractor output length: m = floor(k_1 + 2*log2(epsilon)) # Initialise the Toeplitz extractor with the appropriate # parameters: toeplitz = cryptomite.Toeplitz(n_1, m) # Perform Toeplitz extraction and return the output: return toeplitz.extract(raw_randomness, seed_bits) import cryptomite from math import floor, log2 def improved_randomness_extraction(raw_randomness: list, seed_bits: list, n_1 = 6500000000, epsilon = 10**-10, k_1 = 581295000, r = 0.99) \"\"\" Perform improved randomness extraction for the RNG protocol.",
    "Parameters ----------raw_randomness: list of bits, the outcomes of measurements.",
    "seed_bits: list of bits, generated independently.",
    "n_1: integer, the length of the raw randomness bit string.",
    "epsilon: float, the extractor error."
  ]
}