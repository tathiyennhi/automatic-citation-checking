    "```python 1 import altair as alt 2 import pandas as pd 3 4 def plot(data: pd.DataFrame): 5 # Ensure correct data types 6 data = data.astype({ 7 'Weight_in_lbs': float, 8 'Miles_per_Gallon': float 9 }).dropna(subset=['Weight_in_lbs', ' Miles_per_Gallon']) # Remove rows with missing values 10 11 # Create selection features 12 click = alt.selection multi(fields=['Name']) 13 brush = alt.selection(type='interval', encodings=['x ']) 14 15 # Base chart for scatter plot 16 scatter = alt.Chart(data).mark circle(size=60).encode ( 17 x=alt.X('Weight_in_lbs', axis=alt.Axis(title=' Vehicle Weight in lbs')), 18 y=alt.Y('Miles_per_Gallon', axis=alt.Axis(title ='Fuel Efficiency (MPG)')), 19 color=alt.condition(brush, 'Origin:N', alt.value ('lightgray')), 20 opacity=alt.condition(click, alt.value(0.9), alt.",
