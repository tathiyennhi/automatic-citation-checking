{
  "texts": [
    "I am CEO of ScienceOpen, an interactive discovery environment with publishing services based on open peer review of preprints and global peer review functionalities that can be applied to preprints from any repository.",
    "GD: ASAPbio Board of Directors, Review Commons Advisory Board, bioRxiv Affiliate.",
    "DE: I am a Data Scientist at Sciety/ eLife, helping to bring preprint related data together and trying to make sense of it.",
    "SCE: I run journals carrying out open peer review and promoting use of preprints.",
    "MF: I am Executive Director of the Health Research Alliance, and on the Board of the Center for Open Science, which hosts OSF Preprints."
  ]
}