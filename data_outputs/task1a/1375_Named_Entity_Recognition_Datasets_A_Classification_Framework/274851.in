{
  "texts": [
    "FEW-NERD: fine-grained large-scale dataset created around rare entities.",
    "RadGraph: dataset used in the medical domain for recognizing entities in chest X-ray radiology reports.",
    "SoMeSci: a dataset for identifying software entities and mentions in the scientific domain.",
    "Eset: a dataset designed to facilitate the extraction of information from recipes.",
    "MultiCoNER: provides a cross-language diverse text corpus to address the current challenges of named entity recognition."
  ]
}