  "texts": [
    "(1) Informative cue: A stimulus, typically presented prior to the search display, that carries task-relevant information (e.g., the target's likely location, feature, or onset time).",
    "(2) Noninformative cue.",
    "A distractor that typically does not occur at the same time as the search display.",
    "→ Stimuli Recommendation.",
    "Make sure to use either \"informative cue\" or \"non-informative cue\"."
  ],
  "correct_citations": []
}