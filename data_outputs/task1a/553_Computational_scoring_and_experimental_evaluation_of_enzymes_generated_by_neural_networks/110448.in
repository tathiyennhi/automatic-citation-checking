{
  "texts": [
    "Sequences were deduplicated at 90% using CD-HIT.",
    "Sequences with identity greater than 85%, based on usearch search_global, to a sequence experimentally screened in round 1 were discarded.",
    "The remaining sequences were split into training (90%) and test (10%) sets.",
    "A training MSA was generated.",
    "Phylogenetic trees."
  ]
}