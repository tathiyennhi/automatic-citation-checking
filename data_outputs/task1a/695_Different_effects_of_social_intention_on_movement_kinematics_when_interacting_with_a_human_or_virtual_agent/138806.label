{
  "style": "APA",
  "texts": [
    "Sixteen healthy participants (10 women) aged between 18 and 35 years (M = 21.94, SD = 2.05) voluntarily took part in the study.",
    "They were recruited from the University of Lille.",
    "They were right-handed, as assessed by the Edinburgh Handedness Inventory (Oldfield 1971; mean laterality quotient = 0.83, SD = 0.14), they declared having no perceptual or motor deficit and having a normal or corrected-to-normal visual acuity.",
    "They had no prior information about the hypotheses tested in the study and gave their informed consent before taking part in the experiment.",
    "The sample size of 16 was determined a priori by means of G*Power software (version 3.1.9.4)."
  ],
  "correct_citations": [
    "The sample size of 16 was determined a priori by means of G*Power software (version 3.1.9.4)."
  ]
}