{
  "style": "APA",
  "texts": [
    "Jafar and Babak 31 proposed an efficient and accurate system to diagnose heart disease.",
    "This research developed an ensemble classification model based on a feature selection approach.",
    "The heart disease dataset used by this research is downloaded from the UCI repository which contains 270 records with 13 useful variables.",
    "After selecting the prominent features, seven classifiers namely SVM, NBC, DT MLP, KNN, RF, and LR were used in ensemble learning to predict the disease.",
    "The final prediction over the given sample is done by combining the prediction result of all seven classifiers using the Stacked Ensemble method."
  ],
  "correct_citations": [
    "Jafar and Babak 31 proposed an efficient and accurate system to diagnose heart disease."
  ]
}