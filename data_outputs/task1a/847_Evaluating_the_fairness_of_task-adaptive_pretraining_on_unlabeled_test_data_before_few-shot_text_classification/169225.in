{
  "texts": [
    "What if we overtrain?",
    "Overtraining on labeled test data trivially increases test set performance.",
    "Perhaps overtraining on unlabeled test set text has a similar effect.",
    "To test this hypothesis for text classification, GPT-2 is intentionally overtrained on unlabeled text for 2 epochs instead of 1.",
    "For each of the 25 classification tasks and their subsamples, pretraining for 2 epochs instead of 1 resulted in a lower pretraining loss."
  ]
}