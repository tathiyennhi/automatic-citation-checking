  "bib_entries": {
    "23789785": {
      "title": "The retrorenal colon on computed tomography: a normal variant",
      "abstract": "In a review of 200 patients, the position of the colon in relation to the posterior aspect of the kidneys on CT was studied. A small part of the colon was found in the left retrorenal position in 1.0% of the patients. An illustrative case report of an unusual colonic variation in which the colon cou"
    },
    "2728103": {
      "title": "Interventional procedures in the upper urinary tract",
      "abstract": "The introduction and acceptance of percutaneous nephrostomy as a safe and effective alternative to surgical nephrostomy served as the impetus for the development and expansion of an ever-increasing number of techniques that are encompassed by the term \u201cinterventional uroradiology.\u201d This article reviews many of the non-vascular interventional techniques that have proliferated during the past decade and that are currently used in the kidney, ureter, and perinephric space. The authors emphasize those procedures that are most frequently employed, as well as their own preferences and perspectives on these procedures."
    }
  }
