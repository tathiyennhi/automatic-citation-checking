    "122789771": {
      "title": "Michell cantilevers constructed within a half strip. tabulation of selected benchmark results",
      "abstract": "The paper delivers the benchmark results for the Michell cantilevers constructed within a half strip, for selected values of the ? T /? C ratio, ? T , ? C being the admissible stresses in tension and compression, respectively."
    }
  }
