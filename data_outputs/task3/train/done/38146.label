  "bib_entries": {
    "61608309": {
      "title": "A tactical decision support system based on naturalistic cognitive processes",
      "abstract": "An advanced decision support system has been developed to facilitate Navy tactical decision making, particularly in stressful and high workload environments. The system is unique in that it builds upon cognitive theories and adopts user-centered design and testing approaches. The theoretical basis and operational rationale behind each of the modules of this composite display system are discussed."
    }
  },
