  "bib_entries": {
    "124143536": {
      "title": "Constitutive relations and Clifford algebra in electromagnetism",
      "abstract": "To obtain a determinate system of equations for the electromagnetic field in a material medium certain constitutive relations are needed and the form of these relations is still controversial. On the other hand the Cliord algebra provides a compact covariant form of electromagnetism particularly suitable to discuss constitutive relations. We prove here that Maxwell’s equations impose on these relations some constraints leading to dicult mathematical problems"
    }
  },
