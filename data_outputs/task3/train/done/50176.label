    "28271439": {
      "title": "53BP1 nuclear bodies form around DNA lesions generated by mitotic transmission of chromosomes under replication stress",
      "abstract": "53BP1 is marker of double-strand breaks and accumulates in nuclear foci. These foci are shown to accumulate in G1 at lesions generated by replication stress and may shield lesions from erosion."
    }
