  "bib_entries": {
    "7194331": {
      "title": "Integrated mode-locked lasers in a CMOS-compatible silicon photonic platform",
      "abstract": "Integrated components necessary for a mode-locked laser are demonstrated on a platform that allows for monolithic integration with active silicon photonics and CMOS circuitry. CW lasing and Q-switched mode-locking are observed in the full structures."
    }
  }
}