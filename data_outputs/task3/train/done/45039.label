  "bib_entries": {
    "55420772": {
      "title": "Program complex for cyclotron beam dynamic simulations",
      "abstract": "The program complex in MATLAB intended for particle dynamic simulations is described. Programming in an easy-to-use environment permits creation of models in a short space of time. Advanced graphical tools of MATLAB give good visualization features to created models. The beam dynamic modelling results by the example of two different cyclotron designs are presented."
    }
  },
