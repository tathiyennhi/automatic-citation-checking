  "bib_entries": {
    "15201067": {
      "title": "Secondary homotopy groups",
      "abstract": "Secondary homotopy groups supplement the structure of classical homotopy groups. They yield a track functor on the track category of pointed spaces compatible with fiber sequences, suspensions and loop spaces. They also yield algebraic models of homotopy types with homotopy groups concentrated in two consecutive dimensions."
    }
