  "bib_entries": {
    "19933466": {
      "title": "Why is it taking so long to develop clinically competitive stem cell therapies for CNS disorders?",
      "abstract": "The remarkable advancements in basic stem cell research with implications for several central nervous system disorders have so far not been translated into clinically effective therapies. Here I discuss some of the underlying problems and how they could be overcome."
    }
  },
