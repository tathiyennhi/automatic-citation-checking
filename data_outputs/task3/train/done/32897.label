  "bib_entries": {
    "97641163": {
      "title": "Porous silicon as carrier for controlled delivery of doxorubicin anticancer agent",
      "abstract": "One of the topics of the biomedical research is to design and develop new drug delivery systems able to perform time-controlled release of medicals with target specificity. Porous silicon, characterized by macropores of 2@mm average diameter, with a 200nm thick nanoporous coverage, was produced and its potential applications as drug-carrier were investigated. Doxorubicin loaded porous silicon bits exhibited a time-depending drug delivery profile that is in trend with the cytotoxicity of adenocarcinoma cancer cells exposed to bits."
    }
  },
