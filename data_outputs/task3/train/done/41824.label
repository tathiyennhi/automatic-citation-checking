  "bib_entries": {
    "29566282": {
      "title": "TreeSAAP: selection on amino acid properties using phylogenetic trees",
      "abstract": "Summary: The software program TreeSAAP measures the selective influences on 31 structural and biochemical amino acid properties during cladogenesis, and performs goodness-of-fit and categorical statistical tests. Availability: The TreeSAAP package (executables for Windows PC or Macintosh OSX, Java source code, documentation, and instruction manual) is available at http://genome.cs.byu.edu/treesaap.htm. UNIX version is available upon request."
    }
