  "bib_entries": {
    "84683309": {
      "title": "Sugar distribution in sweet stalk sorghum",
      "abstract": "Among the seventeen cultures of sweet stalk sorghum screened for their juice and sugar content at two different stages, IS 9889 contained the highest percentage of total sugars. Sugar content was found to increase from the soft dough stage to the dead ripe stage. Analysis of the internodes revealed that the midportions of the stalk contained higher amounts of sugars than the other parts."
    }
  },
