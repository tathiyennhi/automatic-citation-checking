  "bib_entries": {
    "8820759": {
      "title": "Premature Therapeutic Antimicrobial Treatments Can Compromise the Diagnosis of Late Periprosthetic Joint Infection",
      "abstract": "Background ::: In the absence of positive cultures and draining sinuses, the diagnosis of periprosthetic joint infection (PJI) relies on laboratory values. It is unknown if administration of antibiotics within 2 weeks before diagnostic evaluations can affect these tests in patients with PJI."
    }
