  "bib_entries": {
    "34955258": {
      "title": "ImmPort: disseminating data to the public for the future of immunology",
      "abstract": "The immunology database and analysis portal (ImmPort) system is the archival repository and dissemination vehicle for clinical and molecular datasets created by research consortia funded by the National Institute of Allergy and Infectious Diseases Division of Allergy, Immunology, and Transplantation. With nearly 100 datasets now publicly available and hundreds of downloads per month, ImmPort is an important source for raw data and protocols from clinical trials, mechanistic studies, and novel methods for cellular and molecular measurements. To facilitate data transfer, templates for data representation and standard operating procedures have also been created and are also publicly available. ImmPort facilitates transparency and reproducibility in immunology research, serves as an important resource for education, and enables newly generated hypotheses and data-driven science."
    }
  },
