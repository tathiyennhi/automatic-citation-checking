  "bib_entries": {
    "6453837": {
      "title": "Associations between objectively assessed physical activity levels and fitness and selfreported health-related quality of life in community-dwelling older adults",
      "abstract": "Background ::: Previous studies investigated the associations between health-related quality of life (HRQoL) and self-reported physical activity (PA) and/or self-reported physical fitness which are not the most reliable methods to assess PA and fitness. Therefore, this study aimed to examine the associations between HRQoL and each of objectively assessed habitual PA and physical fitness."
