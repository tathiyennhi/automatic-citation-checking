  "bib_entries": {
    "82630849": {
      "title": "Stimulation of teliospore germination in smut fungi",
      "abstract": "Preheating and heated teliospore extracts have been found to be stimulatory to germination of the teliospores of ten different smut fungi used in this study. The effect is mostly on the percentage of germination."
    }
  },
