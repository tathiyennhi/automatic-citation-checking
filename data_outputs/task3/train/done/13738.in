  "bib_entries": {
    "46438603": {
      "title": "The trigger system of the CHORUS experiment",
      "abstract": "A new apparatus for detection of \u03bd\u03bc \u2192 \u03bd\u03c4 oscillation has been successfully constructed and operated by the CHORUS Collaboration for the CERN-WA95 experiment. The design, implementation and performance of the electronic trigger system is described. A trigger efficiency of 99% was measured for \u03bd\u03bc charged-current events and 90% for neutral-current events. \u00a9 1999 Elsevier Science B.V. All rights reserved."
    }
  }
}