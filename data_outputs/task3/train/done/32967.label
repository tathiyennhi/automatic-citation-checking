  "bib_entries": {
    "95357513": {
      "title": "Influence of hydrodynamics on Giardia cyst inactivation by ozone. Study by kinetics and by \"CT\" approach",
      "abstract": "This Research Note deals with the problem of providing appropriate disinfection from one of the most resistant microorganisms (the Giardia cysts) while trying to provide a more strict and logical approach to the “CT” concept. A further discussion of the U.S. Environmental Protection Agency (EPA) disinfection requirements in accordance with the kinetics and hydraulics of the ozonation process will be made in order to reconsider the definition of detention time. The main objective is the comparison of two possible approaches for determination of the disinfection conditions. The first implies consideration of the kinetics and hydraulics of the ozonation process. The second is based only on the hydrodynamics data and the use of an additional hypothesis known as the concept of the “CT” value."
    }
  },
