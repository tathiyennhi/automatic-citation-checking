  "bib_entries": {
    "123229984": {
      "title": "Mesoscale energy generated in the boundary layer",
      "abstract": "We examine the kinetic energy that may be generated from surface heating. Cumulonimbus, cumulus, mesoscale and large-scale conversion of potential into kinetic energy can be identified in an idealized way, as distinct processes. Each has a characteristic thermodynamic efficiency."
    }
  }
