  "bib_entries": {
    "22188764": {
      "title": "Characterisation of glyoxalase I in a streptozocin-induced mouse model of diabetes with painful and insensate neuropathy",
      "abstract": "Aims/hypothesis ::: Diabetic peripheral neuropathy (DN) is a common complication of diabetes; however, the mechanisms producing positive or negative symptoms are not well understood. The enzyme glyoxalase I (GLO1) detoxifies reactive dicarbonyls that form AGEs and may affect the way sensory neurons respond to heightened AGE levels in DN. We hypothesised that differential GLO1 levels in sensory neurons may lead to differences in AGE formation and modulate the phenotype of DN."
    }
  },
