  "bib_entries": {
    "15179380": {
      "title": "A Strong coupling test of S duality",
      "abstract": "By studying the partition function of $N=4$ topologically twisted supersymmetric Yang-Mills on four-manifolds, we make an exact strong coupling test of the Montonen-Olive strong-weak duality conjecture. Unexpected and exciting links are found with two-dimensional rational conformal field theory."
    },
    "121026126": {
      "title": "Topological Actions From Twisted Supersymmetric Theories",
      "abstract": "Abstract It has recently been shown that a certain twisting of N =2 supersymmetric gauge theory yields a purely topological Yang-Mills action invariant under a fermionic transformation that resembles BRST. In this paper we construct more of these topological models, including one with an N =2 BRST-antiBRST symmetry, from twists of N =4 supersymmetric Yang-Mills."
    }
  }
