  "bib_entries": {
    "3535258": {
      "title": "New Insights into the Epithelial-to-Mesenchymal Transition in Cancer",
      "abstract": "The role of the epithelial-to-mesenchymal transition (EMT) in cancer progression is a long-debated issue. Recent evidence shows that EMT is not a prerequisite for cancer metastasis, but does confer chemoresistance. Future studies are needed to profile EMT events in different cancer types and under different circumstances to explore their potentials as therapeutic targets."
