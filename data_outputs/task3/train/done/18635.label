  "bib_entries": {
    "8494630": {
      "title": "Metric feature indexing for interactive multimedia search",
      "abstract": "We address the problem of interactive event search in large video archives, using multimedia cues derived from both audio and visual information. Content-based search tools are limited in their ability to quickly respond to ad hoc queries, where a user defines an event of interest on the fly from several video clips. We show that an index organizing pre-computed features can be used to determine the highest-scoring detections while significantly reducing the number of clips examined, and that this approach is compatible with state of the art event search using late fusion over several multimedia cues. In experiments with the TRECVID Multimedia Event Detection (MEDTEST) data, we show that the top 100 detections can be determined by examining only about 1% of the video archive, and that time-limited mean average precision is significantly improved relative to a comparable approach from the literature."
    },
    "70334585": {
      "title": "IR feature embedded BOF indexing method for near-duplicate video retrieval",
      "abstract": "Due to the explosive increase in online videos, near-duplicate video retrieval (NDVR) has attracted much researcher attention. NDVR has very wide applications, such as copyright protection, online video monitoring, and automatic video tagging. Local features serve as elementary building blocks in many NDVR algorithms, and most of them exploit the local volume information using a bag of features (BOF) representation. However, such representation ignores potentially valuable information about the global distribution of interest points. Moreover, the discriminative power of the local descriptors is significantly reduced by the quantizer in BOF. Our motivation is that if we use the global features to classify the same or similar keyframes into the same class, it will be very useful in improving the performance of NDVR. In this paper, we present an improved radon transform (IR) feature which captures the detailed global geometrical distribution of interest points. It is calculated by using the 2D discrete Radon transform, and then applying a principal component analysis. Such IR feature is not only invariant to the geometry transformations but also robust to the noises. In addition, we propose a fusion strategy to combine the BOF representation with the global IR feature for further improving the recognition accuracy. Convincing experimental results on several publicly available datasets demonstrate that our proposed approach outperforms the state-of-the-art approaches in NDVR."
    },
    "57763361": {
      "title": "A review of feature indexing methods for fast approximate nearest neighbor search",
      "abstract": "Fast feature matching is of crucial importance for time-critical applications in computer vision. The main goal of this work is to provide a comprehensive review of the state-of-the-art approaches dealing with the problem of feature indexing. Crucially, indexing methods can be grouped into four classes, including space partitioning, clustering, hashing, and product quantization. The methods are deeply presented, discussed, and linked to each other. An empirical report of performance analysis is also provided to characterize the studied methods. Lastly, we give comments on possible room of improvements for some indexing schemes."
    }
  },
