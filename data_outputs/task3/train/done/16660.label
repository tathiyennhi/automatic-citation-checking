  "bib_entries": {
    "110898587": {
      "title": "A study of five years of tractor-related fatalities in Iowa",
      "abstract": "Agricultural tractor-related fatalities in Iowa for the five years 1988 through 1992 were analyzed. One hundred thirty-six fatalities from 131 fatal incidents reported in Iowa’s newspapers were used as the data source. There were no deaths in overturns involving tractors equipped with a rollover protective structure (ROPS). Based on years of productive life lost, it is estimated that tractor fatalities cost Iowa a minimum of $7.25 million per year."
    }
