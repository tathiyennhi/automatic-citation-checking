  "bib_entries": {
    "96886571": {
      "title": "Situ Observation of Pit Initiation of Passivated Az91 Magnesium Alloy",
      "abstract": "The initiation and growth process of pit on passivated AZ91 magnesium alloy in an atmosphere of water vapor was studied using an environmental scanning electron microscope (ESEM). The results showed that pitting corrosion only occurred at the place with the segregation of salt particles. The mechanism for pit initiation was discussed."
