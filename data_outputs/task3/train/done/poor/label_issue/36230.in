  "bib_entries": {
    "1736605": {
      "title": "Logic Programming on a Neural Network",
      "abstract": "We propose a method of doing logic programming on a Hopfield neural network. Optimization of logical consistency is carried out by the network after the connection strengths are defined from the logic program; the network relaxes to neural states corresponding to a valid (or near-valid) interpretation."
    },
    "22472109": {
      "title": "Upgrading Logic Programming in Hopfield Network",
      "abstract": "The convergence property for doing logic programming in Hopfield network can be accelerated by using new relaxation method. This paper shows that the performance of the Hopfield network can be improved by using a relaxation rate to control the energy relaxation process. The capacity and performance of these networks is tested by using computer simulations. It was proven by computer simulations that the new approach provides good solutions."
    }
  }
}