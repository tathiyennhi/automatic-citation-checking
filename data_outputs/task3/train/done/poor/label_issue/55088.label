  "bib_entries": {
    "5264273": {
      "title": "Exact controllability of complex networks",
      "abstract": "Although it has been possible to calculate the conditions for exerting complete control over a directed complex network, for undirected and weighted networks this calculation is inexact. Yuan et al. develop a general framework for determining the controllability of any complex network."
    },
    "17745433": {
      "title": "On quantitatively measuring controllability of complex networks",
      "abstract": "This letter deals with the controllability issue of complex networks. An index is chosen to quantitatively measure the extent of controllability of given network. The effect of this index is analyzed based on empirical studies on various classes of network topologies, such as random network, small-world network, and scale-free network."
