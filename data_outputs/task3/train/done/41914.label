  "bib_entries": {
    "23171534": {
      "title": "Metabolism and cancer: the circadian clock connection",
      "abstract": "Evidence indicates that the disruption of the circadian clock might be directly linked to cancer. As described here, alterations in clock function could lead to aberrant cellular proliferation, DNA damage responses and altered metabolism."
    }
