  "bib_entries": {
    "31238468": {
      "title": "Light and the human circadian clock",
      "abstract": "The circadian clock can only reliably fulfil its function if it is stably entrained. Most clocks use the light–dark cycle as environmental signal (zeitgeber) for this active synchronisation. How we think about clock function and entrainment has been strongly influenced by the early concepts of the field’s pioneers, and the astonishing finding that circadian rhythms continue a self-sustained oscillation in constant conditions has become central to our understanding of entrainment."
    }
  },
