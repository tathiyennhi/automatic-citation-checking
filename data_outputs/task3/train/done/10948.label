  "bib_entries": {
    "112386060": {
      "title": "Search on the management model of opening experimental teaching in universities",
      "abstract": "Compared with the traditional experimental teaching,by the model of opening experimental teaching for the students,the capabilities of innovative thought,experiential design and scientific research can be effectively trained.Only by the proper management,the purpose of opening experiment can be ensured.As an example of opening experiential management model applied in practice,the links of gathering subject,booking time,putting in practice and examining are introduced and the existing problems and games which are related with reformation and development of opening experiment are discussed."
    }
  },
