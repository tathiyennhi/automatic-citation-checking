  "bib_entries": {
    "95552591": {
      "title": "Reference samples for electron microprobe analysis",
      "abstract": "The chemical analyses of twenty-six minerals, four natural glasses, and one synthetic glass prepared for use as microprobe reference samples are presented. New chemical analyses of minerals and revised analyses of several minerals published previously are included. Details of sample preparation are described and the homogeneity of the samples has been tested by the homogeneity index."
    }
