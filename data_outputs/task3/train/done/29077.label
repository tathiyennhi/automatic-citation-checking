  "bib_entries": {
    "117771948": {
      "title": "Discrete competitive and cooperative models of Lotka-Volterra type",
      "abstract": "The dynamics of discrete Lotka–Volterra system of two species is investigated. It is shown that the proposed discrete models for competitive and cooperative systems possess “dynamical consistency” with their continuous counterparts."
    }
