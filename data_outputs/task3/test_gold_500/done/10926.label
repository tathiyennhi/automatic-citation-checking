  "bib_entries": {
    "9026014": {
      "title": "Dhrystone: A synthetic systems programming benchmark",
      "abstract": "Reflecting current data on the use of programming language constructs in systems programming, a synthetic benchmark is constructed based on the distribution appearing in the data. The benchmark executes 100 Ada statements that are balanced in terms of the distribution of statement types, data types, and data locality. Pascal and C versions of the benchmark are discussed."
    }
  },
