  "bib_entries": {
    "30395700": {
      "title": "Improving survival of culture bacteria in frozen desserts by microentrapment",
      "abstract": "Lactobacillus bulgaricus cells were entrapped in beads of calcium alginate and evaluated for their ability to survive freezing processes. Cells survived freezing (without agitation) in ice milk mix much better than in distilled water, and more entrapped cells survived than did cells that were not entrapped. Glycerol and mannitol were cryoprotective, but glucose was not, when each was added (6%) separately to the beads. Entrapment protected the lactobacilli in batch frozen and continuously frozen ice milk mixes. The percentage of survival for entrapped and unentrapped cells in continuously frozen ice milk approximated 90 and 40%, respectively. Lactobacilli survived better in beads with mean diameters > 30 microns than in those averaging 15 microns. Addition of entrapped lactobacilli had no measurable effect on the sensory characteristics of the ice milk."
    }
  },
