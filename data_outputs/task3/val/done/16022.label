  "bib_entries": {
    "24959330": {
      "title": "Incisive imaging and computation for cellular mysteries: lessons from abscission",
      "abstract": "The final cleavage event that terminates cell division, abscission of the small, dense intercellular bridge, has been particularly challenging to resolve. Here, we describe imaging innovations that helped answer long-standing questions about the mechanism of abscission. We further explain how computational modeling of high-resolution data was employed to test hypotheses and generate additional insights. We present the model that emerges from application of these complimentary approaches. Similar experimental strategies will undoubtedly reveal exciting details about other underresolved cellular structures."
    }
  },
