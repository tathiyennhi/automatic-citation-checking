  "bib_entries": {
    "57597911": {
      "title": "Meta-analysis, decision analysis, and costeffectiveness analysis: methods for quantitative synthesis in medicine",
      "abstract": "The techniques of meta-analysis, decision analysis and cost-effectiveness analysis play an increasingly important role in the formulation of clinical practice guidelines and in decisions about health policy and financing. The design and implementation of studies that use these methods are explained with details of how to interpret results. Sufficient detail is presented to enable a novice to do a simple analysis and those who already carry out such studies will find a mine of helpful information herein. The book will also help policy-makers to better understand the results of such studies and their implications in practice."
    }
