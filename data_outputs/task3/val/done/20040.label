  "bib_entries": {
    "14818693": {
      "title": "Bivariant Hopf cyclic cohomology",
      "abstract": "For module algebras and module coalgebras over an arbitrary bialgebra, we define two types of bivariant cyclic cohomology groups called bivariant Hopf cyclic cohomology and bivariant equivariant cyclic cohomology. These groups are defined through an extension of Connes' cyclic category $\\Lambda$. We show that, in the case of module coalgebras, bivariant Hopf cyclic cohomology specializes to Hopf cyclic cohomology of Connes and Moscovici and its dual version by fixing either one of the variables as the ground field. We also prove an appropriate version of Morita invariance for both of these theories."
    }
  },
