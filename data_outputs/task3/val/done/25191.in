  "bib_entries": {
    "91134488": {
      "title": "Gold nanoparticle aggregation enables colorimetric sensing assays for enzymatic decarboxylation",
      "abstract": "Monitoring enzymatic processes is of fundamental importance for the understanding of the associated biological phenomena. In this work, we show that amino acid decarboxylase activity can be readily monitored by a colorimetric assay with gold nanoparticles (AuNPs), which undergo selective product-induced aggregation. Once the carboxylate group is eliminated, the resulting diamine products trigger AuNP aggregation, leading to a significant color change. Furthermore, this new method provides a rapid way for potential inhibitor screening."
    }
  }
}