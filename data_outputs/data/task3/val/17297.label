  "bib_entries": {
    "121251158": {
      "title": "Some homoclinic connections of a novel integrable generalized nonlinear Schrödinger equation",
      "abstract": "Homoclinic connections of unstable planewaves are constructed for a novel integrable generalized nonlinear Schrodinger equation studied by Lenells and Fokas (2009 Nonlinearity 22 11–27). Three instability regions are identified and compared using explicit examples in the case of a single unstable wavenumber."
    },
    "120358095": {
      "title": "Lattice representation and dark solitons of the FokasLenells equation",
      "abstract": "This work is devoted to an integrable generalization of the nonlinear Schrodinger equation proposed by Fokas and Lenells. I discuss the relationships between this equation and other integrable models. Using the reduction of the Fokas–Lenells equation to the already known ones I obtain the N-dark soliton solutions."
    }
