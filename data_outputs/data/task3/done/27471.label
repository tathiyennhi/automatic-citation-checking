  "bib_entries": {
    "29082016": {
      "title": "Computation of glomerular filtration rate with Tc-99m DTPA: An in-house computer program",
      "abstract": "The glomerular filtration rate (GFR) can be computed from the scintigraphic determination of Tc-99m DTPA (diethylenetriaminepentaacetic acid) uptake within the kidneys. The required computations are straightforward and can easily be included in the software of various computers, including a hospital's existing data-processing system. This report presents a complete operational program based on extensive experience with this method. The program is easy to use, allows for adjustments to be made for unusual clinical conditions, and produces a permanent record that can be issued as part of the final report."
    }
  },
