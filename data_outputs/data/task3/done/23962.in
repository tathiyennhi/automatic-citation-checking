  "bib_entries": {
    "113348568": {
      "title": "World vector shoreline",
      "abstract": "The Defense Mapping Agency (DMA) has developed a digital data file at a nominal scale of 1:250,000, containing shorelines, international boundaries and country names and known as the World Vector Shoreline (WVS). The file was developed with these features in support of geographic information systems, command, control and communications systems. The WVS has been designed to fit varying applications and is convertible to other system specific formats."
    }
  }
}