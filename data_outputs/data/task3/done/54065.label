  "bib_entries": {
    "118681985": {
      "title": "Superluminal Radio Sources",
      "abstract": "Several compact radio sources studied with VLBI show apparent transverse velocities much greater than the speed of light. This review is a summary of VLBI observations of these “superluminal” sources as of August 1981. The physical models proposed to explain this phenomenon are also discussed."
    }
