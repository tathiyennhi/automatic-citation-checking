  "bib_entries": {
    "3090990": {
      "title": "Solutions to Horava Gravity",
      "abstract": "Recently Horava proposed a nonrelativistic renormalizable theory of gravitation, which reduces to Einstein's general relativity at large distances, and that may provide a candidate for a UV completion of Einstein's theory. In this Letter, we derive the full set of equations of motion, and then we obtain spherically symmetric solutions and discuss their properties. We also obtain solutions for the Friedmann-Lema\u00eetre-Robertson-Walker cosmological metric."
    }
  }
}