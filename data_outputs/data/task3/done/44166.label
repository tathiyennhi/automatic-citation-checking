  "bib_entries": {
    "88527925": {
      "title": "The use of Boolean algebra in the study of neural networks",
      "abstract": "Field trials with zinc phosphide and bromadiolone were carried out in houses of Jawahar nagar and Jhalana region of Jaipur respectively. Pre-treatment rodent population was counted by capture, mark, release and recapture method. Zinc phosphide was used in 1% and 2% concentrations for one day exposure while bromadiolone was used in 0.005% concentration for one and two days exposure. Percent control recorded with 1% and 2% zinc phosphide was 79.72 and 86.91 respectively. With bromadiolone 96.77 % control was achieved during one day exposure while control observed with two day exposure of 0.005% bromadiolone was 98.83 %."
    }
