  "bib_entries": {
    "109969537": {
      "title": "Designing Mobile Technology to Enhance Library Space Use: Findings from an Undergraduate Student Competition",
      "abstract": "This case study examines a bottom-up approach for developing mobile, location-aware apps to help students discover campus learning spaces and connect with classmates. An analysis of the competition methodlogy highlights best practices for libraries and other campus units who wish to involve students directly in the design phase of technology development. Findings details student perceptions of campus learning spaces, and in particular reveal ways to organize and present these spaces to fit students' mental models and improve discoverability of resources like reservable study rtooms, loanable technology, and more."
    }
