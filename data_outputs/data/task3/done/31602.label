  "bib_entries": {
    "27586617": {
      "title": "Clinical implications of respiratory-swallowing interactions",
      "abstract": "Purpose of review ::: Swallowing disorders impact the health and quality of millions of lives of patients across the age spectrum. The broad scope of the problem is in contrast to the volume of methods that we have to treat the problem. Investigators are testing interventions that go beyond the swallowing system and are targeting those that cross or overlap with swallowing function. This review will highlight the potential clinical implications of respiratory–swallowing cross-system interaction in health and disease."
    }
  },
