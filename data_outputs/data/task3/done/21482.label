  "bib_entries": {
    "118206506": {
      "title": "Equation Of Motion For The Axial Gravitational Superfield",
      "abstract": "The equation of motion for the axial gravitational superfield is obtained by direct variation of the action for N = 1 supergravity. The left-hand side of the equation is a certain torsion component and the right-hand side is the supercurrent. The question of the cosmological term in supergravity is discussed."
    }
