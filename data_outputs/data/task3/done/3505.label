  "bib_entries": {
    "130396666": {
      "title": "Why is mountain fynbos invasible and which species invade?",
      "abstract": "No account of the effects of fire in mountain fynbos would be complete without considering invasive alien plants. Introduced plants are a striking feature of fynbos landscapes, and they have a marked effect on the functioning of natural ecosystems (Richardson et al. 1991)."
    }
