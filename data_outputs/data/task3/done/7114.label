  "bib_entries": {
    "52859521": {
      "title": "Macrofungal diversity in Colombian Amazon forests varies with regions and regimes of disturbance",
      "abstract": "Here we present the results of fungal biodiversity studies from some selected Colombian Amazon forests in relationship to plant biodiversity and successional stages after slash and burn agriculture. Macrofungal diversity was found to differ between forests occurring in two regions (Araracuara vs Amacayacu) as well as between flooded forests and terra firme forests in the Amacayacu region. Macrofungal biodiversity differed between regeneration states of different age in the Araracuara region. Suitable substrates, especially dead wood that occurred as a result of recent slash and burn agriculture, resulted in the formation of many sporocarps of wood-inhabiting species. Putative ectomycorrhizal species were found in a dipterocarp forest. Fifty two percent of the macrofungal species could not be identified to the species level, but could be assigned to a genus, and it is likely that a significant portion of these represent species new to science. Long term studies are needed to obtain a comprehensive and complete understanding of the diversity and functioning of mycobiota in Amazon forest ecosystems."
    },
    "85704176": {
      "title": "Diversity of Colombian macrofungi (Ascomycota-Basidiomycete)",
      "abstract": "A checklist of the species of Colombian macrofungi cited in the literature is presented. A total of 130 published articles were reviewed. These reported 1239 species of macrofungi belonging to 32 orders and 105 families of Ascomycota and Basidiomycota. Lichens were not included."
    },
    "5295342": {
      "title": "Austroboletus amazonicus sp. nov. and Fistulinella campinaranae var. scrobiculata, two commonly occurring boletes from a forest dominated by Pseudomonotes tropenbosii (Dipterocarpaceae), in Colombian Amazonia",
      "abstract": "Two boletes that frequently form fruiting bodies in Pseudomonotes tropenbosii forests are described from Colombian Amazonia. One is a new species of Austroboletus here described as A. amazonicus and the other one is Fistulinella campinaranae var. scrobiculata Singer, which is a new record for Colombia. Macromorphological, micromorphological and habitat data for these species are provided as well as DNA sequence data of the internal transcribed spacer (ITS) regions and the D1/D2 domains of the large subunit (LSU) ribosomal DNA."
    },
    "84592129": {
      "title": "Litter fall and retranslocation of nutrients in a refertilized and prescribed burned Pinus elliottii plantation",
      "abstract": "Abstract Nutrient transfer in vegetative and reproductive litter fall was measured in an experimentally refertilized (60 kg ha−1 phosphorus applied in 1979) and prescribed burned (May 1981) Pinus elliottii plantation in coastal southeast Queensland between 1980 and 1983. Transfer of nutrients in pollen and internal retranslocation of nutrients from dying needles were estimated for 1 year. There were no responses in litter production to refertilization or prescribed burning, however, by 1982 refertilization had increased needle fall mean annual phosphorus concentrations from 0.011% in unfertilized treatments to 0.017% in refertilized treatments. In 1983, phosphorus concentrations increased from 0.013 to 0.020%. There was a corresponding response in needle fall phosphorus amounts which, in 1983, increased from 0.63 kg ha−1 year−1 in unfertilized treatments to 0.94 kg ha−1 year−1 in refertilized treatments. No other concentration or nutrient amount responses to refertilization or prescribed burning were detected. Mean annual litter fall amounted to 6.5 t ha−1, of which 67% was needles, and contained 22.8 kg ha−1 nitrogen, 1.5 kg ha−1 phosphorus (unfertilized treatments), 4.5 kg ha−1 potassium, 3.1 kg ha−1 sodium, 33.9 kg ha−1 calcium and 9.3 kg ha−1 magnesium. Reproductive organs, of which pollen was the main component, contributed between 29 and 57% of the total nitrogen, phosphorus and potassium transferred in litter fall although comprising only 15% of the litter fall biomass. Needle fall was strongly seasonal with 60% of the annual total falling during a pronounced autumn peak. Needle nitrogen, phosphorus and potassium concentrations, in contrast, had sharp minima at this time. It is suggested that this seasonal pattern is related to internal competition for these nutrients between old needles and young expanding needles, cones and seeds. Nitrogen, phosphorus and potassium contents (mg per fascicle) of old fascicles declined by between 61 and 84% before abscission during autumn whereas sodium, calcium and magnesium contents did not decrease significantly. Annual amounts of nutrients translocated from dying needles, calculated using the autumn decline in nutrient content and the annual number of dead fascicles in litter fall of 25.6 · 106 ha−1, were estimated to be 25.7 kg ha−1 nitrogen, 2.5 kg ha−1 phosphorus (in the control) and 9.3 kg ha−1 potassium."
    },
    "12504190": {
      "title": "DNA barcoding survey of Trichoderma diversity in soil and litter of the Colombian lowland Amazonian rainforest reveals Trichoderma strigosellum sp. nov. and other species",
      "abstract": "The diversity of Trichoderma (Hypocreales, Ascomycota) colonizing leaf litter as well as the rhizosphere of Garcinia macrophylla (Clusiaceae) was investigated in primary and secondary rain forests in Colombian Amazonia. DNA barcoding of 107 strains based on the internal transcribed spacers 1 and 2 (ITS1 and 2) of the ribosomal RNA gene cluster and the partial sequence of the translation elongation factor 1 alpha (tef1) gene revealed that the diversity of Trichoderma was dominated (71 %) by three common cosmopolitan species, namely Trichoderma harzianum sensu lato (41 %), Trichoderma spirale (17 %) and Trichoderma koningiopsis (13 %). Four ITS 1 and 2 phylotypes (13 strains) could not be identified with certainty. Multigene phylogenetic analysis and phenotype profiling of four strains with an ITS1 and 2 phylotype similar to Trichoderma strigosum revealed a new sister species of the latter that is described here as Trichoderma strigosellum sp. nov. Sequence similarity searches revealed that this species also occurs in soils of Malaysia and Cameroon, suggesting a pantropical distribution."
    }
  },
