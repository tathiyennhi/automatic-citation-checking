  "bib_entries": {
    "7449911": {
      "title": "Restoration of cone vision in a mouse model of achromatopsia",
      "abstract": "Loss of cone function in the central retina is a pivotal event in the development of severe vision impairment for many prevalent blinding diseases. Complete achromatopsia is a genetic defect resulting in cone vision loss in 1 in 30,000 individuals. Using adeno-associated virus (AAV) gene therapy, we show that it is possible to target cones and rescue both the cone-mediated electroretinogram response and visual acuity in the Gnat2cpfl3 mouse model of achromatopsia."
    }
  },
