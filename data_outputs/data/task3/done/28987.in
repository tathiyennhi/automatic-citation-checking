  "bib_entries": {
    "123567014": {
      "title": "Harmonic functions starlike in the unit disk",
      "abstract": "Abstract Complex-valued harmonic functions that are univalent and sense-preserving in the unit disk \u0394 can be written in the form f = h + \u1e21, where h and g are analytic in \u0394. We give univalence criteria and sufficient coefficient conditions for normalized harmonic functions that are starlike of order \u03b1, 0 \u2264 \u03b1"
    }
  }
