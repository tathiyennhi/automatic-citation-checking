  "bib_entries": {
    "119623402": {
      "title": "Existence and a priori bounds for electrostatic Klein-Gordon-Maxwell systems in fully inhomogeneous spaces",
      "abstract": "We prove the existence and uniform bounds for the electrostatic Klein\u2013Gordon\u2013Maxwell systems in the inhomogeneous context of a compact Riemannian manifold when the mass potential, balanced by the phase, is small in a quantified sense. Phase compensation for the electrostatic Klein\u2013Gordon\u2013Maxwell systems and the positive mass theorem are used in a crucial way."
    }
  }
