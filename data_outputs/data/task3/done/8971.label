  "bib_entries": {
    "37496487": {
      "title": "It is not worthwhile to perform ileoscopy on all patients",
      "abstract": "Background ::: It remains controversial whether ileoscopy should be attempted in all patients. Although the ease of ileoscopy and the diagnostic yield have been well described, there have been no studies describing the value of the diagnostic yield in altering clinical management. We carried out a study to ascertain whether it is worthwhile to perform ileoscopy in all patients having a colonoscopy."
    }
  },
