  "bib_entries": {
    "39225667": {
      "title": "A new approach to practical acute toxicity testing",
      "abstract": "A method for the investigation of the acute toxicity of an unknown chemical substance, with an estimation on the LD50, is described. Using this, it is possible to obtain with 13 experimental animals adequate information on the acute toxicity and on the LD50. This method has no limitations and applies to drugs, agricultural and industrial chemicals. It can be used for every route of administration."
    }
