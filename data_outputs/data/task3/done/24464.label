  "bib_entries": {
    "54676588": {
      "title": "BRST Quantization In The Siegel Gauge",
      "abstract": "From a formal generalization to N copies of the free open string field theory BRST-quantized in the Siegel gauge we reproduce the BRST quantization of the free closed bosonic string field theory and obtain the one of massless higher spin field theories."
    }
  },
