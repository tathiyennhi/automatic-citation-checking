  "bib_entries": {
    "110204000": {
      "title": "Cancellation frame size for a Quasi single bit detector in asynchronous CDMA channel",
      "abstract": "The effect of the cancellation frame size in a quasi-single-bit (QSB) detection scheme for serial successive cancellation CDMA is determined against average probability of bit error and the number of users. It is shown that a cancellation frame size of three bits is the best choice for decreasing interference from other users."
    },
    "57583250": {
      "title": "Serial interference cancellation method for CDMA",
      "abstract": "A serial interference canceller for CDMA is proposed where progressive stages in the canceller strip away the noise. For 31 chip Gold codes, 17 users, and imperfect power control the proposed canceller can obtain an average BER of 4*10/sup -6/ compared with 3*10/sup -3/ for a parallel canceller after four stage cancellations. The delay penalty is 21 bit periods."
    }
  }
