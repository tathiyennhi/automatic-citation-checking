  "bib_entries": {
    "111028860": {
      "title": "State codes for lighting and marking of agricultural equipment",
      "abstract": "A review of traffic codes for motor vehicles (MVs) and slow-moving vehicles (SMVs) for ::: all 50 states was conducted. The states codes were searched for lighting and marking ::: requirements using a LEXIS database. A comparison of requirements for headlights, turn ::: signals, amber flashers, reflectors, taillights, and a slow moving vehicle emblem was the ::: primary consideration of this study. Compared to automotive and emergency equipment, ::: lighting and marking requirements for agricultural machinery appear inconsistent and ::: inadequate."
    }
  },
