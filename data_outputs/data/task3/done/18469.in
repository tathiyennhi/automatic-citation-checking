  "bib_entries": {
    "4361041": {
      "title": "Combined pesticide exposure severely affects individual-and colony-level traits in bees",
      "abstract": "Chronic exposure of bumblebees to two pesticides (a neonicotinoid and a pyrethroid) independently and in combination, at concentrations approximating field-level exposure, impairs natural foraging behaviour and increases worker mortality, with knock-on effects for brood development and colony success."
