  "bib_entries": {
    "747037": {
      "title": "Restricted permutations, Fibonacci numbers and k-generalized Fibonacci numbers",
      "abstract": "In 1985 Simion and Schmidt showed that the number of permutations in Sn which avoid 132, 213, and 123 is equal to the Fibonacci number Fn+1. We use generating function and bijective techniques to give other sets of pattern-avoiding permutations which can be enumerated in terms of Fibonacci or k-generalized Fibonacci numbers."
    }
