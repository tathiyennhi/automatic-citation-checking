  "bib_entries": {
    "86788346": {
      "title": "Introduction to the Special issue on interactive graphical data analysis: What is interaction?",
      "abstract": "In this introduction to the special issue of Computational Statistics on interactive graphical data analysis, we first briefly introduce the papers. They cover a lot of ground, from the updating of older statistical environments to the assessment of some of the newest, and there are several interesting examples of interactive graphics applied to data analysis problems."
    }
