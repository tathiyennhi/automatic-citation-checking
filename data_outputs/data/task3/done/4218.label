  "bib_entries": {
    "143706762": {
      "title": "Cardiac-somatic Integration: An Index of Visual Attention",
      "abstract": "Abstract Eighteen 15-week-old, normal full-term infants were presented with photographic slides of a human facial expression. The infant's heart rate, body movement, and visual attention were recorded simultaneously. The results showed that heart rate and body movement were significantly correlated during visual attention but not during inattention. Both heart rate and body movement decelerated significantly when the infants visually attended to the target stimulus. The results are discussed with reference to cardiac-somatic integration in early infancy and its implication as a possible index of attention."
    },
    "143816837": {
      "title": "Developmental Course of Early Cardiac-somatic Integration",
      "abstract": "The degree of cardiac-somatic (i.e., heart rate-body movement) integration in the presence and absence of auditory stimulation, as well as its early developmental course, was examined. Three-and 6-month-old infants were studied to determine whether psychological activity (attention) had a facilitative effect on cardiac-somatic integration, and if so, whether such an effect was age-related. The results showed that both 3-and 6-month-old infants exhibited a significant heart-rate (HR) deceleratory response to stimulus onset, although the response was greater in 6-month-olds than in 3-month-olds. In contrast, both groups Showed a significant body-movement (BM) deceleratory response to stimulus onset, but there was no significant age effect. The results also showed phase-and age-related differences in the magnitude of correlation between HR and BM. The results are discussed in relation to the impact of development and psychological activity on cardiac-somatic integration."
    }
  },
