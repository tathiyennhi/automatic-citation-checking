  "bib_entries": {
    "6179181": {
      "title": "Fast and efficient radiological interventions via a graphical user interface commanded magnetic resonance compatible robotic device",
      "abstract": "The graphical user interface for an MR compatible robotic device has the capability of displaying oblique MR slices in 2D and a 3D virtual environment along with the representation of the robotic arm in order to swiftly complete the intervention. Using the advantages of the MR modality the device saves time and effort, is safer for the medical staff and is more comfortable for the patient."
    }
  },
