  "bib_entries": {
    "23687160": {
      "title": "The type 2 diabetes presumed causal variant within TCF7L2 resides in an element that controls the expression of ACSL5",
      "abstract": "Aims/hypothesis ::: One of the most strongly associated type 2 diabetes loci reported to date resides within the TCF7L2 gene. Previous studies point to the T allele of rs7903146 in intron 3 as the causal variant at this locus. We aimed to identify the actual gene(s) under the influence of this variant."
    }
