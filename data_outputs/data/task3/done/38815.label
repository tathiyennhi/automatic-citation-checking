  "bib_entries": {
    "141798504": {
      "title": "What is Carnal Hermeneutics?",
      "abstract": "What is the sense of sense? How do we read between the lines of skin and flesh? How do we interpret the world with our bodily senses, and especially those senses long neglected in western philosophy—taste and touch? How, in other words, do we discern the world as this or that, as hospitable or hostile, as attractive or repulsive, as tasty or tasteless, as living or dying? These are key questions of carnal hermeneutics."
    }
  },
