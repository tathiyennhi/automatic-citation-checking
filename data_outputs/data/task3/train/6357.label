  "bib_entries": {
    "122736598": {
      "title": "Descent property and global convergence of Fletcher-Reeves method with inexact line search",
      "abstract": "Si on utilise une recherche de ligne inexacte qui satisfait des conditions standards on peut demontrer que la methode de Fletcher-Reeves a une propriete de descente et est globalement convergente en un certain sens"
    },
    "119895031": {
      "title": "Efficient hybrid conjugate gradient techniques",
      "abstract": "Descent property and global convergence proofs are given for a new hybrid conjugate gradient algorithm. Computational results for this algorithm are also given and compared with those of the Fletcher-Reeves method and the Polak-Ribiere method, showing a considerable improvement over the latter two methods. We also give new criteria for restarting conjugate gradient algorithms that prove to be computationally very efficient. These criteria provide a descent property and global convergence for any conjugate gradient algorithm using a nonnegative update β."
    },
    "15235695": {
      "title": "Global convergence properties of conjugate gradient methods for optimization",
      "abstract": "This paper explores the convergence of nonlinear conjugate gradient methods without restarts, and with practical line searches. The analysis covers two classes of methods that are globally convergent on smooth, nonconvex functions. Some properties of the Fletcher–Reeves method play an important role in the first family, whereas the second family shares an important property with the Polak–Ribiere method. Numerical experiments are presented."
    },
    "119976017": {
      "title": "Global convergence result for conjugate gradient method",
      "abstract": "Conjugate gradient optimization algorithms depend on the search directions, ::: ::: $$\\begin{gathered} s^{(1)} = - g^{(1)} , \\hfill \\\\ s^{(k + 1)} = - g^{(k + 1)} + \\beta ^{(k)} s^{(k)} ,k \\geqslant 1, \\hfill \\\\ \\end{gathered} $$ ::: ::: with different methods arising from different choices for the scalar β(k). In this note, conditions are given on β(k) to ensure global convergence of the resulting algorithms."
    }
