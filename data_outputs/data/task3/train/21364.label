  "bib_entries": {
    "29280800": {
      "title": "To mesh or not to mesh with polypropylene: does carcinogenesis in animals matter?",
      "abstract": "Polypropylene in sheets has been been found to be carcinogenic in some laboratory animals. Although no human carcinogenicity has been reported, long-term follow-up in humans implanted with polypropylene mesh will be important."
    }
