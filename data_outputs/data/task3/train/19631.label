  "bib_entries": {
    "232773": {
      "title": "Provision of air traffic management over SWIM",
      "abstract": "This paper evaluates the use of System Wide Information Management (SWIM) to support sharing of safety ATM data link information from Controller Pilot Data Link Communications (CPDLC) and Automatic Dependent Surveillance (ADS), in addition to advisory information. The convergence of both advisory and safety critical information into IP-based (including ATN/IPS) networks makes the use of common infrastructure resources a viable possibility for data link and SWIM service providers in a cost-effective way."
    }
