  "bib_entries": {
    "85373460": {
      "title": "New record of the snake Drymobius chloroticus (Cope, 1886) (Squamata: Colubridae) from Hidalgo",
      "abstract": "We report the first record of the snake Drymobius chloroticus (Cope 1886) from Hidalgo State, Mexico. This new record is based on a single juvenile male specimen collected in the municipality of Tepehuacan of Guerrero, Hidalgo. This report fills a gap between the closest localities airline 490.1 km2 ca. NW in Los Tuxtlas, Veracruz, and airline 42.7 ca. km2 SE in the vicinity Xilitla, San Luis Potosi, Mexico."
    }
  },
