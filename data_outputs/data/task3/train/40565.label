  "bib_entries": {
    "121755076": {
      "title": "Morita equivalence for idempotent rings",
      "abstract": "Abstract In this paper, the classical theory of Morita equivalence is extended to idempotent rings which do not necessarily have an identity element. In this case, the role of progenerators is played by the unital and codivisible modules which generate all the unital modules."
    }
