  "bib_entries": {
    "118961504": {
      "title": "Conservative Discretization of the Landau Collision Integral",
      "abstract": "We describe a density, momentum, and energy conserving discretization of the nonlinear Landau collision integral. Our algorithm is suitable for both the finite-element and discontinuous Galerkin methods and does not require structured meshes. The conservation laws for the discretization are proven algebraically and demonstrated numerically for an axially symmetric nonlinear relaxation problem."
    }
