  "bib_entries": {
    "87906346": {
      "title": "Utilization of harvester ant debris by tenebrionid beetles",
      "abstract": "Tenebrionid beetles with defensive secretions are able to use these secretions as weapons against ants. The beetles feed on the organic matter that harvester ants collect around the entrance to their nests. By exploiting the organic matter collected and concentrated by the ants, the beetles greatly increase the amount of food available to them."
    }
  },
