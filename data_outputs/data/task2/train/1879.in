  ],
  "bib_entries": {
    "144045559": {
      "title": "The popular number seven or number preference",
      "abstract": "When asked to choose numbers, people show clear preferences, not only on first but also on second choices. The origins of these preferences remain obscure but may be affected by the way choices are made."
    },
    "146814978": {
      "title": "Number and color responses of some college students: Preliminary evidence for a \"blue seven phenomenon",
      "abstract": "490 college students were requested to write down (a) a number between 0 and 9 and (b) the name of a color. The number 7 and the color blue were by far the most frequently written. Sex differences were also found with respect to both number and color choices."
    },
    "145778128": {
      "title": "Investigation of the \"blue seven phenomenon\" in elementary and junior high school children",
      "abstract": "533 elementary and junior high school children were requested to write down a number between 0 and 9 and the name of a color. The number 7 and the color blue were by far the most frequently written (p < .001 in both cases). These results were consistent with those obtained in an earlier study (Simon, 1971) with college students."
    }
  }
}