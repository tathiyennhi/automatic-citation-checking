    "16692421": {
      "title": "Semistable points with respect to real forms",
      "abstract": "We consider actions of real Lie subgroups G of complex reductive Lie groups on Kahlerian spaces. Our main result is the openness of the set of semistable points with respect to a momentum map and the action of G."
    },
