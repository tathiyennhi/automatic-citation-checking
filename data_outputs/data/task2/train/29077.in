  ],
  "bib_entries": {
    "120118179": {
      "title": "A nonstandard discretization method for Lotka-Volterra models that preserves periodic solutions",
      "abstract": "Three discretization schemes are applied to the Lotka\u2013Volterra competition models with an interior fixed point. The local dynamics of these discrete-time models near the interior fixed point are analysed. One of the discrete models shows dynamical consistency with the continuous model in the sense that it produces periodic solutions when the continuous model does posses periodic solutions while the other two discrete models produce solutions which either spiral into or out of the fixed point. The discrete model derived from Kahan's discretization method preserves Hopf bifurcations in the continuous model."
    },
    "117771948": {
      "title": "Discrete competitive and cooperative models of Lotka-Volterra type",
      "abstract": "The dynamics of discrete Lotka\u2013Volterra system of two species is investigated. It is shown that the proposed discrete models for competitive and cooperative systems possess \u201cdynamical consistency\u201d with their continuous counterparts."
    },
    "118919276": {
      "title": "A nonstandard finite-difference scheme for the Lotka-Volterra system",
      "abstract": "Most numerical integration schemes for the Lotka-Volterra system have the property that the computed solutions spiral when in fact the actual solutions are periodic corresponding to closed curves. We show that a direct application of the nonstandard methods of Mickens allows the construction of a finite-difference scheme that is dynamically consistent with the differential equations. Numerical results are given to support this result."
    }
  }
}