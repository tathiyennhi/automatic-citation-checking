  "bib_entries": {
    "33879416": {
      "title": "Convolution neural network for contour extraction of corneal endothelial cells",
      "abstract": "The corneal endothelial cells exist on the human’s cornea. To extract every cell contour from them is indispensable for the assessment of cell condition. However, it is difficult to distinguish the contour of large cells from the cytoplasm because of their homogeneity of gray scale pattern. In this paper, we construct the CNNs for the precise cell extraction regardless to scale of the cell. We utilize software library Caffe as a Deep Learning framework. We show the effectiveness of CNNs for the contour extraction of corneal endothelial cells."
    }
