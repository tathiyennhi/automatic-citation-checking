  "bib_entries": {
    "22304282": {
      "title": "The viability of hamster spermatozoa stored in the isthmus of the oviduct: the importance of sperm-epithelium contact for survival",
      "abstract": "When hamster mate shortly after the onset of estrus, spermatozoa are stored in the lower oviduct (isthmus) during the preovulatory period; The present study was performed to determine what proportion of the spermatozoa in the isthmus until fertilization."
    }
