  "bib_entries": {
    "11927007": {
      "title": "Sjögren's syndrome: terminology",
      "abstract": "In spite of our continuously improved pathobiological understanding, there is still no consensus on terminology and disease criteria in Sjogren's syndrome (SS). This survey points out discrepencies in the current description of the syndrome, and argues for a new classification model. We suggest that the present nomenclatures for the global disease (Sjogren's disease) and disease subsets (primary and secondary SS) be retained until additional pathobiological insights give rise to new and descriptive terms. We do find evidence, however, to support a new terminology and classification of the main immunoinflammatory manifestations of primary SS. Accordingly, three exocrine and four non-exocrine subgroups of disease manifestations are here defined. The usefulness of the proposed model should be evaluated in clinical studies and in a debate engaging all of the medical specialities involved."
    }
  },
