  "bib_entries": {
    "12496311": {
      "title": "Comparison between fascicular and whole sural nerve biopsy",
      "abstract": "Sural nerve regeneration and sensation were evaluated in 16 subjects five or more years after fascicular or whole nerve biopsy. Conduction studies demonstrated successful nerve regeneration in all subjects who had whole nerve biopsy. Postbiopsy interrogation revealed no long-term pain or paresthesias but a high incidence of tactile-induced dysesthesias. No significant difference was seen when areas of sural sensory loss were compared in fascicular and whole nerve biopsy groups. We conclude that whole nerve biopsy should be recommended in preference to fascicular biopsy since it is simpler, has greater diagnostic potential, and allows for a more complete morphological evaluation."
    }
  },
