  "bib_entries": {
    "26702021": {
      "title": "First record of natural Tritrichomonas foetus infection of the feline uterus",
      "abstract": "Tritrichomonas foetus was found in the uterus of a cat with pyometra and in the faeces of three other cats in the same household, one of which had chronic diarrhoea. This is the first report of a feline uterine infection with T. foetus and also the first time T. foetus has ever been diagnosed in animals in Norway. The diagnosis was made by microscopic examination and sequencing studies."
    }
  }
