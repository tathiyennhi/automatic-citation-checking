  "bib_entries": {
    "27988540": {
      "title": "Complex Kerr-Newman geometry and black hole thermodynamics",
      "abstract": "We establish that in the functional-integral expression for the grand partition function, the thermodynamic properties of a charged, rotating black hole are derived from a complex geometry. The corresponding real ``thermodynamical'' action is constructed explicitly."
    }
