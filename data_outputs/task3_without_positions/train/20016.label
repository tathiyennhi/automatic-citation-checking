  "bib_entries": {
    "15980210": {
      "title": "On the differentiability of Cauchy horizons",
      "abstract": "Chrusciel and Galloway constructed a Cauchy horizon that is nondifferentiable on a dense set. We prove that in a certain class of Cauchy horizons densely nondifferentiable Cauchy horizons are generic. We show that our class of densely nondifferentiable Cauchy horizons implies the existence of densely nondifferentiable Cauchy horizons arising from partial Cauchy surfaces and also the existence of densely nondifferentiable black hole event horizons."
    }
