  "bib_entries": {
    "205379900": {
      "title": "Bacterial small RNA-based negative regulation: Hfq and its accomplices",
      "abstract": "A large group of bacterial small regulatory RNAs (sRNAs) use the Hfq chaperone to mediate pairing with and regulation of mRNAs. Recent findings help to clarify how Hfq acts and highlight the role of the endonuclease RNase E and its associated proteins (the degradosome) in negative regulation by these sRNAs. sRNAs frequently uncouple transcription and translation by blocking ribosome access to the mRNA, allowing other proteins access to the mRNA. As more examples of sRNA-mediated regulation are studied, more variations on how Hfq, RNase E, and other proteins collaborate to bring about sRNA-based regulation are being found."
    }
  },
