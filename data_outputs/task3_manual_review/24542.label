  "bib_entries": {
    "39636569": {
      "title": "Medical intractability in children evaluated for epilepsy surgery",
      "abstract": "We assessed the value of therapeutic reevaluation and additional pharmacotherapy in medically intractable children referred for epilepsy surgery. In 21 children with antiepileptic drug treatment omissions, correcting the omission was ineffective in 19 (90%). Two children (10%), both of whom had structural lesions, achieved significant seizure control with high-dose carbamazepine monotherapy. Therapeutic reevaluation is indicated in all medically intractable children prior to epilepsy surgery."
    }
