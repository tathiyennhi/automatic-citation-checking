  "bib_entries": {
    "10446": {
      "title": "Euthanasia and physician-assisted suicide",
      "abstract": "Euthanasia and physician-assisted suicide (PAS) are much publicized topics these days. Because physicians are increasingly likely to be confronted with clinical situations involving euthanasia and PAS, they need to be aware of the history, public opinion, medical opinion and practice, and ethical and legal issues involved with euthanasia and PAS."
    }
