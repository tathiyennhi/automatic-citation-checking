  "bib_entries": {
    "122434908": {
      "title": "Coupling Boltzmann and Navier Stokes equations by half fluxes",
      "abstract": "We introduce an adaptative coupling of the Boltzmann and Navier?Stokes equations to compute hypersonic flows around a vehicle at high altitude. The coupling is achieved by matching half fluxes at the interface of the Boltzmann and Navier?Stokes domains. The domains are determined automatically by computing local kinetic residuals on a preliminary Navier?Stokes solution. Our method is developed here for monoatomic gases. Different numerical results illustrate its validity and limits."
    }
  },
