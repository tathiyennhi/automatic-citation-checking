  "bib_entries": {
    "167975058": {
      "title": "Health/healthy food: is there a difference?",
      "abstract": "Comparisons are made of the definitions of health/healthy foods in the literature, and those of 683 farmers, companies and multiple retailers researched by questionnaire survey. Recommends classification on a clearly defined continuum of terms to allow flexibility on perceptions and the development of new foods."
    }
