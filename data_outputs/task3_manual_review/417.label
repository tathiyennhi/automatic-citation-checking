  "bib_entries": {
    "56424566": {
      "title": "Design, development, and performance of x-ray mirror coatings for the athena mission",
      "abstract": "We report the latest results on coating design optimisation and optics performance for the present Ir/B4C baseline coating and alternative designs and materials, including bilayers and linear graded multilayers. We make use of X-ray reflectometry (XRR) to test both coating performance and robustness."
    }
