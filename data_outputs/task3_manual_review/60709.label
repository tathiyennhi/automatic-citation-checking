  "bib_entries": {
    "36099763": {
      "title": "Uranyl acetate, a stain and a fixative",
      "abstract": "The ultrastructural appearance of the Plasmodium gallinaceum sporozoite in Aedes aegypti mosquito midgut is studied using five different fixation procedures. The use of dilute aqueous uranyl acetate after double fixation with either citrate- or phosphate-buffered glutaraldehyde and OsO4 gives the best preservation of membranous structures although specific differences are noted. Aqueous uranyl acetate, used after double fixation and before dehydration, not only stains the membranes, but markedly improves their preservation as evidenced by their continuity and trilaminar configuration."
    }
  },
