  "bib_entries": {
    "55792554": {
      "title": "Thermal modeling of aluminum electrolytic capacitors",
      "abstract": "A comprehensive thermal model for screw-terminal aluminum electrolytic capacitors is developed. The test methodology and data upon which the model is based are discussed. Exact one-dimensional solutions, multi-dimensional heat equations and finite-element analysis (FEA) model simulation results are presented. The effects of conduction, heat sinking, natural (free) convection, forced convection and heat radiation are quantified and compared. Complex issues, such as anisotropism and multi-phase heat transfer, are discussed. A comparison of model results to test data is presented. Varying capacitor construction techniques are evaluated."
    }
