  "bib_entries": {
    "12345975": {
      "title": "The storm has cleared: lessons from the CD28 superagonist TGN1412 trial",
      "abstract": "The life-threatening cytokine-release syndrome suffered by six volunteers in a Phase I clinical trial following administration of the CD28 superagonist antibody TGN1412 (developed by TeGenero) in March 2006 was completely unpredicted by the preclinical studies. Here, Thomas Hünig, main founder of TeGenero, describes the recent investigations into what went wrong and discusses the lessons learnt for future clinical trials."
    }
  },
