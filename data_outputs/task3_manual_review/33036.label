  "bib_entries": {
    "4390203": {
      "title": "Silver atom and strand numbers in fluorescent and dark Ag:DNAs",
      "abstract": "We use tandem HPLC-mass spectrometry with in-line spectroscopy to identify silver atom numbers, NAg, of 10 to 21 in visible- to infrared-emitting Ag:DNA complexes stabilized by oligonucleotide monomers and dimers. Qualitatively different absorbance spectra from bare, same-NAg silver clusters point to silver-base interactions as the origin for the color of Ag:DNAs."
    }
