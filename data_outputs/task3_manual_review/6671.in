  "bib_entries": {
    "119235286": {
      "title": "Pseudo-differential calculus in an anisotropic Gelfand-Shilov setting",
      "abstract": "We study some classes of pseudo-differential operators with symbols a admitting anisotropic exponential type growth at infinity. We deduce mapping properties for these operators on Gelfand–Shilov spaces. Moreover, we deduce algebraic and certain invariance properties of these classes."
    }
  }
}