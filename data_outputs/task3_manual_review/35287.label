  "bib_entries": {
    "119512521": {
      "title": "Strings from IIB matrices",
      "abstract": "D-string action is constructed from IIB matrices, a spacetime commutator is essential in this construction. This hints at the central role of the spacetime uncertainty relation in a unified formulation of strings. Vertex operators of fundamental strings are also discussed."
    }
  },
