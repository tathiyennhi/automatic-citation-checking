  "bib_entries": {
    "30093941": {
      "title": "Discovery of thiophene inhibitors of polo-like kinase",
      "abstract": "The discovery and development of a series of thiophenes as potent and selective inhibitors of PLK is described. Identification and characterization of 2, a useful in vitro PLK inhibitor tool compound, is also presented."
    }
