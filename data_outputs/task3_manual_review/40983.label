  "bib_entries": {
    "205089172": {
      "title": "Bioprosthetic mitral valve thrombosis complicating antiphospholipid antibody syndrome, successfully treated with thrombolysis",
      "abstract": "The incidence of bioprosthetic valve thrombosis and related embolic complications is extremely rare, obviating the need for long-term anticoagulation. As a result, experience in the diagnosis and treatment of bioprosthetic valve thrombosis is fairly limited. We report the first case of antiphospholipid antibody syndrome presenting as bioprosthetic mitral valve thrombosis, 15 months after valve replacement, and successfully treated with thrombolytic therapy."
    }
  },
