  "bib_entries": {
    "37763789": {
      "title": "Epidemiology and clinical manifestations of cutaneous T-cell lymphoma",
      "abstract": "Cutaneous T-cell lymphoma (CTCL) encompasses a constellation of diseases of malignant clonal T lymphocytes that present initially in the skin. Within this disease spectrum, mycosis fungoides, and the Sezary syndrome are best known. Progress in the understanding of the T-cell malignancies now places other clinical entities within this disease classification. The authors review the epidemiology and clinical manifestations of CTCL."
    },
    "22391915": {
      "title": "Cutaneous T-cell lymphomas",
      "abstract": "The \"Clinical Snapshot\" series provides a concise examination of a clinical presentation including history, treatment, patient education, and nursing measures. Using the format here, you are invited to submit your \"Clinical Snapshot\" to Dermatology Nursing."
    }
  },
