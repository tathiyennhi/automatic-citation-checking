  "bib_entries": {
    "6993126": {
      "title": "Bafilomycins: a class of inhibitors of membrane ATPases from microorganisms, animal cells and plant cells",
      "abstract": "Various membrane ATPases have been tested for their sensitivity to bafilomycin A1, a macrolide antibiotic. F1F0 ATPases from bacteria and mitochondria are not affected by this antibiotic. In contrast, E1E2 ATPases--e.g., the K+-dependent (Kdp) ATPase from Escherichia coli, the Na+,K+-ATPase from ox brain, and the Ca2+-ATPase from sarcoplasmic reticulum--are moderately sensitive to this inhibitor. Finally, membrane ATPases from Neurospora vacuoles, chromaffin granules, and plant vacuoles are extremely sensitive. From this we conclude that bafilomycin A1 is a valuable tool for distinguishing among the three different types of ATPases and represents the first relatively specific potent inhibitor of vacuolar ATPases."
    }
  },
  "generator": "fallback"
}