  "bib_entries": {
    "155062687": {
      "title": "Amenities and property values in a model of an urban area",
      "abstract": "The dependence of property values on a schedule of ‘amenities’ is examined in the case of a ‘small’ and ‘open’ city and in the case of a ‘closed’ city. Questions concerned with the predictability and interpretation of changes in equilibrium property values following an improvement in amenities are considered in these cases. The problem of identifying the implicit demand for amenities from a single equilibrium rent schedule is also addressed."
    }
