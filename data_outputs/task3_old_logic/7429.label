  "bib_entries": {
    "119410619": {
      "title": "Electronic noise in optical homodyne tomography",
      "abstract": "The effect of the detector electronic noise in an optical homodyne tomography experiment is shown to be equivalent to optical loss if the detector is calibrated by measuring the quadrature noise of the vacuum state. An explicit relation between the electronic noise level and the equivalent optical efficiency is obtained and confirmed in an experiment with a narrow-band squeezed vacuum source operating at an atomic rubidium wavelength."
    }
  },
