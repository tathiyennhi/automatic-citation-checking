  "bib_entries": {
    "85252975": {
      "title": "A sensitive assay for flavin mononucleotide using the bacterial bioluminescence reaction",
      "abstract": "Abstract Investigations of the feasibility of the bacterial bioluminescence reaction as the basis of an extraterrestrial life detection system have resulted in the development of a photometric technique for the quantitative detection of 10−11 gm of flavin mononucleotide (FMN). The FMN, reduced with sodium borohydride and palladium chloride in solution, is a required component of the in vitro bacterial bioluminescent reaction. Under the conditions of the procedure, we have found a linear relationship between light intensity and concentration of reduced FMN. The concentrations of FMN in bacteria, urine, and blood have been determined."
    }
  }
}