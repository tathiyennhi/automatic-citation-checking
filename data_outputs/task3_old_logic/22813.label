  "bib_entries": {
    "22755722": {
      "title": "Atrial septal defect in a child with Ito syndrome",
      "abstract": "Hypomelanosis of Ito is a rare neurocutaneous disorder described for the first time in 1952. It is characterized by depigmented skin areas often associated with ocular, musculoskeletal and neurological abnormalities. We report the case of a newborn affected by hypomelanosis of Ito with an atrial septal defect."
    }
