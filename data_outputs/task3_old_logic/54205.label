  "bib_entries": {
    "62605219": {
      "title": "The end of Nostradamus: Killing predictive check-in without feeling guilty",
      "abstract": "Computer systems for receiving serial issues have existed for over 50 years. Their functionality has gradually become more complex and predictive. A new generation of check-in systems is currently being developed, some of which have decided to include less-complex check-in systems. The presenters discuss the history of check-in systems, and give case studies of two new systems that have chosen a simpler design for serials receiving."
    }
