  "bib_entries": {
    "42111141": {
      "title": "Ageing of lymphocytes and lymphocytes in the aged",
      "abstract": "Abstract Immunosenescence is a complex process involving multiple reorganizational and developmentally regulated changes, rather than simple unidirectional decline in all functions. Here, these compensatory modulations are reviewed with reference to the importance of integrating information on cellular alterations identified in vitro with data on global physiological changes in the aged environment with which these cells interact in vivo ."
    }
  }
