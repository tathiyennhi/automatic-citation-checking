  "bib_entries": {
    "9836487": {
      "title": "Genome sequence of the food spoilage yeast Zygosaccharomyces bailii CLIB 213 T",
      "abstract": "ABSTRACT The ascomycetous yeast Zygosaccharomyces bailii is one of the most problematic spoilage yeasts in food and beverage industries, due to its exceptional resistance to various stresses. A better understanding of the molecular mechanisms underlying these stress resistance phenotypes might help develop strategies to improve food quality. Thus, we determined and annotated the genome sequence of the strain Z. bailii CLIB 213T (= CBS 680)."
    }
