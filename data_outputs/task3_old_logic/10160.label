  "bib_entries": {
    "14924133": {
      "title": "Oxidative stress status in childhood obesity: a potential risk predictor",
      "abstract": "Background ::: Childhood obesity characterized by excessive fat in the body is one of the most serious health problems worldwide due to the social, medical, and physiological complications. Obesity and associated diseases are triggering factors for oxidative stress and inflammation. The aim of this study was to explore the possible association between childhood obesity and inflammatory and oxidative status."
