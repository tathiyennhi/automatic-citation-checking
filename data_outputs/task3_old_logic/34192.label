  "bib_entries": {
    "2228459": {
      "title": "Innate lymphoid cells-a proposal for uniform nomenclature",
      "abstract": "Innate lymphoid cells (ILCs) have key roles in immune responses, lymphoid tissue development and tissue regeneration. Recently, several new ILC subsets were identified. Here, the authors propose the use of a uniform nomenclature to describe all ILC subsets to avoid confusion and further promote the development of this field."
