  "bib_entries": {
    "98919845": {
      "title": "Influence of adding zeolite on membrane filtration resistance in MBR and its decolorizing effect",
      "abstract": "Anaerobic/aerobic membrane bioreactor(MBR) process was applied for simulated dyeing wastewater treatment.The zeolite was added into MBR,and the influence of zeolite dosage on membrane filtration resistance and decolorizing effect were investigated.The results show that at the condition of the effluent flow of 12 L/h and MLSS of 4 g/L,adding zeolite can reduce the membrane filtration resistance and improve the decolorizing rate of the system.The best zeolite dosage for reducing the membrane filtration resistance is 500 mg/L and the best zeolite dosage for improving the decolorizing rate of the system is 1 000 mg/L."
    }
  },
