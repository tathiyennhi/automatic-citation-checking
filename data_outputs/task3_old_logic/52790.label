  "bib_entries": {
    "85374265": {
      "title": "Strain identification of Rhizobium using intrinsic antibiotic resistance",
      "abstract": "The variation in intrinsic resistance to low levels of eight antibiotics was used as an identifying characteristic for 26 Rhizobium leguminosarum strains. The pattern of antibiotic resistance of each strain was a stable property by which rhizobia isolated from root nodules of inoculated Pisum sativum could be recognized. The antibiotic tests for strain identification with R. leguminosarum were applied to R. phaseoli. It was necessary to include reference cultures in tests with this species, as the tests most suitable for the R. leguminosarum strains showed some variability with R. phaseoli."
    }
