  "bib_entries": {
    "15680993": {
      "title": "Quasitriangularity and enveloping algebras for inhomogeneous quantum groups",
      "abstract": "Coquasitriangular universal R matrices on quantum Lorentz and quantum Poincare groups are classified. The results are extended (under certain assumptions) to inhomogeneous quantum groups. Enveloping algebras on those objects are described."
    }
  }
