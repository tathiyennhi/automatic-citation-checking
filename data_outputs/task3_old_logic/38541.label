  "bib_entries": {
    "24916716": {
      "title": "CT of infected bladder diverticulum",
      "abstract": "A case in which pus within a bladder diverticulum simulated a deep pelvic abscess is presented. This pitfall in CT diagnosis should be considered in patients with bladder outlet obstruction with symptoms of infection."
    }
