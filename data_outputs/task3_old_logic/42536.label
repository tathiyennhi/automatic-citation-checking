  "bib_entries": {
    "7640430": {
      "title": "Transcriptional downregulation of S1pr1 is required for the establishment of resident memory CD8+ T cells",
      "abstract": "Jameson and colleagues show that the establishment of resident memory CD8+ T cells in nonlymphoid tissues requires transcriptional downregulation of the trafficking molecule S1P1, mediated by induced loss of the transcription factor KLF2."
    }
