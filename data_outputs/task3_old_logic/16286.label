  "bib_entries": {
    "7924649": {
      "title": "Compensatory modulation of GAP activity in response to oncogenic stimulation",
      "abstract": "GAP is a key negative regulator of the receptor tyrosine kinase (RTK) signal transduction pathway. The purpose of this study was to determine if expression or activity of GAP is modulated by hyperstimulation of the RTK pathway. It was found that cells forced to express wild-type Ha-ras, viral Ha-ras, or v-src exhibit increased GAP activity as compared to control cells. In addition, a novel GAP isoform appears in all ras-expressing NIH3T3 cell clones. These data indicate that there is compensatory regulation of GAP in response to an increase in RTK pathway activity."
    }
  },
