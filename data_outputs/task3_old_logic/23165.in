  "bib_entries": {
    "6445872": {
      "title": "Mercury exposure and cutaneous disease",
      "abstract": "Human contact with mercury has been ongoing for centuries and was previously considered a legitimate means of treating different cutaneous and systemic conditions. Toxicity from this heavy metal may occur from exposure to elemental, inorganic, and organic forms of mercury. This article outlines the signs and symptoms of mercury poisoning and the different clinical conditions with assorted cutaneous findings."
    }
  }
