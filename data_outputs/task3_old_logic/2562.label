    "12848168": {
      "title": "Tools for health: The efficacy of a tailored intervention targeted for construction laborers",
      "abstract": "Objectives ::: Novel approaches to worksite health promotion are needed for high-risk workers who change job sites frequently, and thus may have limited access to worksite health promotion efforts. The objective of this study was to test a behavioral intervention among construction laborers."
    }
