  "bib_entries": {
    "25570562": {
      "title": "A system for the functional evaluation of reconstructive procedures after surgical treatment of tumors of the musculoskeletal system",
      "abstract": "The need for a standardized system of end result reporting of various surgical alternatives after limb salvaging and ablative procedures for musculoskeletal tumors was clearly recognized during the first International Symposium on Limb Salvage (ISOLS) in 1981. During the ensuing four biannual symposia, there has been an ongoing developmental experience with a system extensively field tested in 1989 by the Musculoskeletal Tumor Society (MSTS). This system of functional evaluation has been adopted by the MSTS and ISOLS for their joint studies and program presentation"
    }
  },
