  "bib_entries": {
    "20977066": {
      "title": "A randomized trial of a classroom intervention to increase peers' social inclusion of children with attention-deficit/hyperactivity disorder",
      "abstract": "Objective ::: Interventions for peer problems among children with Attention-Deficit/Hyperactivity Disorder (ADHD) typically focus on improving these children's behaviors. This study tested the proposition that an adjunctive component encouraging the peer group to be socially inclusive of children with ADHD would augment the efficacy of traditional interventions."
    }
