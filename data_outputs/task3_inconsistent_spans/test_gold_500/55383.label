  "bib_entries": {
    "122763937": {
      "title": "Giant broadband nonlinear optical absorption response in dispersed graphene single sheets",
      "abstract": "Researchers show that dispersed functionalized graphene can exhibit broadband nonlinear optical absorption at fluences well below the damage threshold. An optical energy-limiting onset benchmark of 10 mJ cm−2 at a linear transmittance of 70% was obtained for nanosecond visible and near-infrared pulses. The findings shed light on the formation of practical thin films with broadband optical limiting characteristics."
    },
    "99074765": {
      "title": "High-performance optical limiters based on stable phthalocyanine J-type dimers",
      "abstract": "Abstract Low limiting thresholds have been demonstrated on thermally stable phthalocyanine J-type dimeric complexes of Mg and Zn. The effective “threshold” model based on radiative transfer phenomena in nonlinear optical (NLO) media was suggested for exact definition of the nonlinear absorption coefficient and the optical limiting threshold."
    }
