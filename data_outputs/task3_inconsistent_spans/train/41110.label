  "bib_entries": {
    "44372161": {
      "title": "Early acute thrombosis of bioprosthetic mitral valve presenting with cardiogenic shock",
      "abstract": "Early thrombosis of bioprosthetic mitral valves is an extremely rare occurrence. We present an unusual case of a patient with polycythemia presenting with cardiogenic shock, secondary to acute thrombosis of a bioprosthetic mitral valve which was placed 14 months prior to presentation. Our report also reviews predisposing factors and treatment options for bioprosthetic mitral valve thrombosis."
    }
