  "bib_entries": {
    "22630254": {
      "title": "Safety of epidural analgesia in the perioperative care of patients undergoing cytoreductive surgery with hyperthermic intraperitoneal chemotherapy",
      "abstract": "Background ::: The perioperative coagulopathy, hemodynamic instability, and infectious complications that may occur during cytoreductive surgery (CRS) with hyperthermic intraperitoneal chemotherapy (HIPEC) has raised concerns about the safety of epidural analgesia in patients undergoing such procedures."
    }
