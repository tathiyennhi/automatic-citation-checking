  "bib_entries": {
    "145090256": {
      "title": "Family life disruptions: Effects of job-induced structural and emotional interference",
      "abstract": "Workers and their spouses were surveyed to examine the effects on family interactions of two correlates of shift work: (1) interference between job and family roles caused by structural conditions: and (2) emotional interference, indicated by health, mood, and behavioral symptoms. Emotional interference was consistently related to family life outcomes, but structural interference was found to brave little effect on quality of family life. Contrary to predictions, quality of family life was not significantly related to employees' intentions to leave the company."
    },
    "141870000": {
      "title": "Psychological stress in the workplace",
      "abstract": "\"Psychological Stress in the Workplace\" provides an up-to-date and comprehensive account of research on occupational stress. It identifies the sources, consequences and treatments of stress in the workplace from the perspective of organizational psychology, and makes clear recommendations for future work in this area. Illustrated with many examples from field research over the author's 20 years of experience in studying the workplace, this book should be of considerable interest to students and researchers in occupational psychology, as well as managers and trainers."
    }
