  "bib_entries": {
    "14632256": {
      "title": "Unmanned aircraft systems: Spectrum related issues for control and non-payload communications",
      "abstract": "The aim of this paper is to summarize spectrum allocation aspects related to the control and non-payload communications link(s) for unmanned aircraft systems. We take into account the corresponding studies of ITU-R, the position of ICAO and related resolutions of world radiocommunication conferences. In addition, the current situation of the spectrum allocation for unmanned aircraft systems control and non-payload communications links with corresponding limitations are examined."
    }
