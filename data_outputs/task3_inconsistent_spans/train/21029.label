  "bib_entries": {
    "17516856": {
      "title": "Medicinal plant of Thailand. II: chemical studies on the seed kernels of Entada rheedei Sprengel",
      "abstract": "Chemical investigation of a methanolic extract of the seed kernels of Entada rheedei (Fabaceae), a Thai medicinal plant taken for stomachache, led to the isolation of five new compounds, 1-(3,4-dimethoxyphenyl)propan-9-ol O-(6″-O-α-L-arabinopyranosyl)-β-D-glucopyranoside, 1-(3,4,5-trimethoxyphenyl)prop-7-en-9-ol O-(6″-O-α-L-arabinopyranosyl)-β-D-glucopyranoside, and N-(2'-hydroxyethyl)-7-phenylacetamide 2'-O-β-D-glucopyranoside, and entadamide A 2'-O-(4″-O-β-D-glucopyranosyl)-β-D-glucopyranoside and 2'-O-(6″-O-β-D-glucopyranosyl)-β-D-glucopyranosides, together with one known compound, corchoionoside C. Their structures were elucidated on the basis of chemical and spectral evidence."
    }
  },
