  "bib_entries": {
    "85363817": {
      "title": "Cod-end drag as a function of catch size and towing speed",
      "abstract": "This paper reports on a series of flume tank experiments to measure the drag of a number of cod-ends over a range of towing speeds and catch sizes. It is shown that cod-end drag can be described as a function of the towing speed and the maximum frontal area of the cod-end. This suggests that the pressure drag of the catch is the predominant component of the cod-end drag. We also show that cod-end drag increases as solidity and the lateral cod-end motion increases."
    }
  }
}