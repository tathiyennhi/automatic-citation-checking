  "bib_entries": {
    "32629655": {
      "title": "Menin-MLL inhibitors reverse oncogenic activity of MLL fusion proteins in leukemia",
      "abstract": "MLL fusion genes often encode leukemogenic proteins that depend on interaction with menin, a component of the MLL SET1-like histone methyltransferase complex. MI-2 and MI-3 are the first small molecules that can block menin–MLL fusion protein interaction and their oncogenic effects in cells."
