  "bib_entries": {
    "1041890": {
      "title": "Microscopic Origin of the Bekenstein-Hawking Entropy",
      "abstract": "Abstract The Bekenstein-Hawking area-entropy relation S BH = A 4 is derived for a class of five-dimensional extremal black holes in string theory by counting the degeneracy of BPS solition bound states."
