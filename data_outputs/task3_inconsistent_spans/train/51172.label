  "bib_entries": {
    "37444647": {
      "title": "A New Preparative Method for Allylic Indium(III) Reagents by Reductive Transmetalation of π-Allylpalladium(II) with Indium(I) Salts",
      "abstract": "A reductive transmetalation of the π-allylpalladium(II) complexes, generated in situ from a catalytic amount of a palladium(0) complex and a variety of allylic substrates, with indium(I) salts proceeded smoothly in various solvents, providing a new route for allylindium(III) reagents."
    },
    "97714420": {
      "title": "Metal Mediated Allylation of Carbonyl Compounds in Ionic Liquids",
      "abstract": "In, Sn and Zn metals mediate the allylation of carbonyl compounds in [bmim][BF4] or [emim][BF4] to give the corresponding homoallylic alcohols in good to excellent yields. Tin was found to be the metal of choice among the metals examined."
    }
