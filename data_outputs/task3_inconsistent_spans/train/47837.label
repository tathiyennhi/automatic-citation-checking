    "85390149": {
      "title": "Effect of light intensity upon salt marsh benthic microalgal photosynthesis",
      "abstract": "The rate of photosynthesis was measured in the field with in-situ populations of benthic microalgae during both summer and winter in three distinct areas of the salt marshes adjacent to Sapelo Island, Georgia, USA. In the vegetated portions of the marsh, maximum rates of photosynthesis occurred at light intensities higher than the average light intensities beneath the canopy. In the bare creek-bank areas, maximum rates occurred at less than the full sunlight intensities to which the algae are exposed on a clear day. There was a significant seasonal acclimatization to the higher light intensities during the summer months in all three areas. Photoinhibition usually occurred at full light intensities."
    },
    "86679254": {
      "title": "Preliminary observations on the effects of flooding and desiccation upon the net photosynthetic rates of high intertidal estuarine sediments",
      "abstract": "Measurements of gaseous CO2 exchange from high intertidal estuarine sediments revealed that net photosynthetic rates of moist, unflooded sediments were maximal. Flooding of moist sediments with 1–2 mm of agitated seawater reduced net photosynthetic rates by 48–66%. When moist sediments lost 10–15% of their water content CO2 uptake decreased, and high rates of CO2 evolution were observed later as water losses continued."
    }
  },
