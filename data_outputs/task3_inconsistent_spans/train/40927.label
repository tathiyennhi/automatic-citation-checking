  "bib_entries": {
    "1709401": {
      "title": "Severely thrombosed transcatheter aortic valve 9 months after implantation",
      "abstract": "Bioprosthetic aortic valve thrombosis is a rare complication after transcatheter aortic valve implantation; however, one with a high mortality. We describe the case of a patient with a completely thrombosed transcatheter aortic valve prosthesis 9 months after implantation and review the diagnosis and management of this complication."
    }
