  "bib_entries": {
    "5255775": {
      "title": "Expert consensus document: the International Scientific Association for Probiotics and Prebiotics consensus statement on the scope and appropriate use of the term probiotic",
      "abstract": "Probiotics are widely regarded as live microorganisms that, when administered in sufficient amounts, confer a health benefit, but guidance is needed on the most appropriate use of the term. This Consensus Statement outlines recommendations for the scope and definition of the term 'probiotic' as determined by an expert panel convened by the International Scientific Association for Probiotics and Prebiotics in October 2013."
