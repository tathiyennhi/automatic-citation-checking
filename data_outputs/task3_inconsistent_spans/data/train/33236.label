  "bib_entries": {
    "95413771": {
      "title": "Design of a solar photovoltaic-powered mini cathodic protection system",
      "abstract": "A mini cathodic protection (CP) system based on solar photovoltaic power source has been designed and tested in the field. It is concluded that such modular systems are well suited for CP applications especially in remote and hilly terrains."
    }
