  "bib_entries": {
    "121587643": {
      "title": "Remarks on Galois symmetry in rational conformal field theories",
      "abstract": "Abstract We show that a recently discovered Galois symmetry is present in the torus partition function of any rational conformal field theory, as well as chiral fusion rings. S matrix elements are linear combinations over Q of roots of unity. An example of \u2322su(2) WZNW theory is discussed."
    }
  }
