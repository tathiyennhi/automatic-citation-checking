  "bib_entries": {
    "95967750": {
      "title": "Application of 2-point Pad\u00e9 approximants to the ground state of the 2-dimensional hydrogen atom in an external magnetic field",
      "abstract": "The 2-dimensional hydrogen atom in an external field \u03bbr2 is important in certain problems of solid-state physics. The exact results for the ground state are obtained from the numerical solution of the radial Schrodinger equation and are compared with various 2-point Pade approximants. Terms to order \u03bb4 in the low-field RS expansion are combined with 5 terms in the high-field expansion in order to obtain the Pade approximants. The results indicate that the best approximants have relative errors in the range 10\u22128 to 10\u22125 throughout the interval \u03bb = 0 \u22ef 4."
    }
  }
