  "bib_entries": {
    "4390344": {
      "title": "Arteriolar niches maintain haematopoietic stem cell quiescence",
      "abstract": "Immunofluorescence imaging and computational modelling are used to study the spatial distribution of different cell types within the haematopoietic stem cell (HSC) niche; findings show that quiescent HSCs associate specifically with small arterioles that are preferentially found in the endosteal bone marrow and are essential in maintaining this quiescence."
