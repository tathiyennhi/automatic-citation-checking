  "bib_entries": {
    "2537573": {
      "title": "Bone marrowon-a-chip replicates hematopoietic niche physiology in vitro",
      "abstract": "Bone marrow formed in a cylindrical PDMS device implanted in a mouse can be surgically removed and cultured for a week in vitro without losing any of the hallmarks of in vivo bone marrow niches."
