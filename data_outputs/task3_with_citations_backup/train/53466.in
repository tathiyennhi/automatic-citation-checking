  "bib_entries": {
    "24149308": {
      "title": "Minimal Gerschgorin tensor eigenvalue inclusion set and its approximation",
      "abstract": "For a tensor, its minimal Gersgorin tensor eigenvalue inclusion set is presented. By establishing a sufficient and necessary condition for the elements belonging to this set, we give a sequence of approximation sets and prove that the limit of this sequence is the minimal Gersgorin tensor eigenvalue inclusion set for an irreducible tensor."
    }
  }
}