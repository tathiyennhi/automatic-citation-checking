  "bib_entries": {
    "4361484": {
      "title": "Rapamycin fed late in life extends lifespan in genetically heterogeneous mice",
      "abstract": "Although inhibition of the TOR signalling pathway extends lifespan in invertebrates, it was unknown whether mTOR signalling inhibition has similar effects in mammalian species. Here, feeding mice the drug rapamycin — an inhibitor of the mTOR pathway — late in life is shown to extend lifespan by 9–14%; currently, the only way to extend lifespan in rodents is by severe dietary restriction."
