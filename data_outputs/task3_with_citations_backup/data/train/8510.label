  "bib_entries": {
    "98491563": {
      "title": "Templated synthesis of interlocked macrocyclic ligands, the catenands. Preparation and characterization of the prototypical bis-30 membered ring system",
      "abstract": "Abstract We describe here the detailed template synthesis of a copper(I) catenate. Demetallation leads to the corresponding free ligand, a catenand. Both molecules are made of two interlocked 30 membered rings."
    }
