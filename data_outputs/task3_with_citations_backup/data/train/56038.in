  "bib_entries": {
    "8682326": {
      "title": "Uncovering the roles of rare variants in common disease through whole-genome sequencing",
      "abstract": "Genome-wide association studies have explained only a small fraction of the genetic basis of complex diseases. This Review argues that rare variants could have a substantial effect on genetic predisposition to common disease, and the authors outline discovery strategies based on whole-genome sequencing for identifying these genetic risk factors."
    }
