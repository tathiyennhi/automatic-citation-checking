  "bib_entries": {
    "25848624": {
      "title": "Early high-dose intravenous methylprednisolone is effective in preserving retinal nerve fiber layer thickness in patients with neuromyelitis optica",
      "abstract": "Background ::: Neuromyelitis optica (NMO) is a recurring inflammatory neurological disease characterized by severe optic neuritis and myelitis. The purpose of this study was to determine whether the retinal nerve fiber layer thickness (RNFLT) is correlated with the clinical presentations in patients with NMO and to determine the clinical factors that lead to poor visual outcomes."
