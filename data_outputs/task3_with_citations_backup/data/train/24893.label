  "bib_entries": {
    "1817473": {
      "title": "Virus entry: open sesame",
      "abstract": "Detailed information about the replication cycle of viruses and their interactions with host organisms is required to develop strategies to stop them. Cell biology studies, live-cell imaging, and systems biology have started to illuminate the multiple and subtly different pathways that animal viruses use to enter host cells. These insights are revolutionizing our understanding of endocytosis and the movement of vesicles within cells. In addition, such insights reveal new targets for attacking viruses before they can usurp the host-cell machinery for replication."
    }
