  "bib_entries": {
    "699452": {
      "title": "16-Channel Digitally Tunable External-Cavity Laser with Nanosecond Switching Time",
      "abstract": "We present a 16-channel 100-GHz-spacing digitally tunable packet-switching transmitter based on a novel external-cavity laser design. The transmitter can switch within 0.8 ns between its channels at 0-dBm output power and <0.7-dB penalty when switched from just above threshold and within 20 ns and 0.5-dB penalty when switched from below threshold. All 16 channels are within 2.1 GHz of the ITU grid."
    },
    "45339081": {
      "title": "× 32λ × 10) Gbit/s Polarization-Multiplexed, Wide-Colored Optical Packet Switching Achieved by Polarization Independent High-Speed PLZT Switch",
      "abstract": "We demonstrate 640 (2 x 32λ x 10) Gbit/s polarization-multiplexed, wide-colored optical packet switching by using a polarization-independent and high-speed (<; 2.5 ns) PLZT optical switch to attain error-free (bit-error-rate <; 10 ~ 9) operation for all 64 payload channels."
    }
  },
