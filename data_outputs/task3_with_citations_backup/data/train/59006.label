  "bib_entries": {
    "8702814": {
      "title": "Paying twice: questions over high cost of cystic fibrosis drug developed with charitable funding",
      "abstract": "Deborah Cohen and James Raftery ask why one of the first drugs to be developed by a partnership between a charity and a drug company also ended up being one of the world’s most expensive drugs. Why didn’t such philanthropy lead to greater patient access?"
    }
