  "bib_entries": {
    "33694324": {
      "title": "A multiyear quality control study of alpha-track radon monitors",
      "abstract": "Quality control exposures of commercial alpha-track radon monitors have been conducted approximately weekly at the U.S. Department of Energy (DOE) Grand Junction Projects Office since early 1987 in support of DOE remedial action programs. The results of these exposures provide a historical record of the comparative performances of these radon monitors."
